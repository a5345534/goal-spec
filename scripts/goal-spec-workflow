CHANGE_NAME_RE = re.compile(r"^[a-z0-9][a-z0-9-]*$")
CJK_RE = re.compile(r"[\u3400-\u4dbf\u4e00-\u9fff]")
QUESTION_MARK_RE = re.compile(r"[?？]")
NOT_DOING_YET_RE = re.compile(
    r"(?i)(not doing yet)|"
    r"(暫不處理|暫不進行|暫不執行|暫時不做|尚不進行|目前不做|現在不做|先不做|還不做|不會先做|未處理事項)"
)
CHINESE_NEGATIVE_RE = re.compile(r"^\s*(?:[-*+]\s+)?(?:不|不要|不會|不能|未|無|沒有|暫不|尚不|先不)")
ENGLISH_TEMPLATE_LABELS_FOR_CJK = (
    (r"(?im)^\s*Problem & Scope Grilling\s*$", "Problem & Scope Grilling"),
    (r"(?im)^\s*-\s*Intended outcome\s*:", "Intended outcome"),
    (r"(?im)^\s*-\s*Improvement intent\s*:", "Improvement intent"),
    (r"(?im)^\s*-\s*Scope uncertainty\s*:", "Scope uncertainty"),
    (r"(?im)^\s*-\s*Current baseline / source context\s*:", "Current baseline / source context"),
    (r"(?im)^\s*Design tree status\s*$", "Design tree status"),
    (r"(?im)^\s*-\s*Resolved branches\s*:", "Resolved branches"),
    (r"(?im)^\s*-\s*Open blocking branch\s*:", "Open blocking branch"),
    (r"(?im)^\s*Blocking clarification(?:\s*\([^)]*\))?\s*$", "Blocking clarification"),
    (r"(?im)^\s*-\s*Question\s*:", "Question"),
    (r"(?im)^\s*-\s*Why this matters\s*:", "Why this matters"),
    (r"(?im)^\s*-\s*My recommended answer\s*:", "My recommended answer"),
    (r"(?im)^\s*-\s*Options\s*:", "Options"),
    (r"(?im)^\s*Options\s*:", "Options"),
    (r"(?im)^\s*Not doing yet\s*:", "Not doing yet"),
)


def has_cjk(text: str) -> bool:
    return bool(CJK_RE.search(text))


def has_not_doing_yet_section(text: str) -> bool:
    return bool(NOT_DOING_YET_RE.search(text))


def is_negative_reference_line(line: str) -> bool:
    stripped = line.strip().lower()
    return bool(re.search(r"(?i)^\s*(?:[-*+]\s+)?(?:no|not|without)\b", stripped)) or bool(CHINESE_NEGATIVE_RE.search(line))

