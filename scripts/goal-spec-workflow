def cmd_role_start(args):
    root = project_root(args.project_root)
    try: change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("role-start","invalid_artifact","usage_error",EXIT_USAGE,errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args,'artifact_dir',None), change_name)
    role = getattr(args,'role','') or ''
    step = getattr(args,'step','') or ''
    run_id = f"{utc_now().replace(':','').replace('-','').replace('T','-')[:15]}-{role}"
    role_run = {"schemaVersion":SCHEMA_VERSION,"changeName":change_name,"runId":run_id,"role":role,"modelClass":{"collector":"evidence-collector","judge":"value-judge","writer":"spec-writer","explainer":"explainer-writer","reviewer":"strict-reviewer"}.get(role,""),"step":step,"status":"complete","startedAt":utc_now(),"boundaryAssertions":{"noValueDecision":True,"noOpenSpecWriting":True,"noRuntimePlanning":True,"noConcreteModelId":True}}
    runs_dir = base / ROLE_RUNS_DIR / role
    runs_dir.mkdir(parents=True, exist_ok=True)
    write_json(runs_dir / f"{run_id}.json", role_run)
    dump(json_report("role-start","pass","recorded",EXIT_PASS,runId=run_id))
    return EXIT_PASS


def cmd_role_complete(args):
    root = project_root(args.project_root)
    try: change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("role-complete","invalid_artifact","usage_error",EXIT_USAGE,errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args,'artifact_dir',None), change_name)
    role = getattr(args,'role','') or ''
    step = getattr(args,'step','') or ''
    run_id = getattr(args,'run_id',None)
    if not run_id:
        dump(json_report("role-complete","invalid_artifact","missing_run_id",EXIT_USAGE,errors=["--run-id required"]))
        return EXIT_USAGE
    path = base / ROLE_RUNS_DIR / role / f"{run_id}.json"
    if not path.exists():
        dump(json_report("role-complete","invalid_artifact","not_found",EXIT_INVALID_ARTIFACT,errors=[f"role-run {run_id} not found"]))
        return EXIT_INVALID_ARTIFACT
    data = read_json(path)
    data["completedAt"] = utc_now()
    data["status"] = "complete"
    artifact_name = getattr(args,'artifact',None)
    if artifact_name:
        ap = base / artifact_name
        if ap.exists():
            data.setdefault("outputArtifacts",[]).append(artifact_name)
            data.setdefault("outputDigests",{})[artifact_name] = _canonical_json_digest(read_json(ap))
    write_json(path, data)
    dump(json_report("role-complete","pass","completed",EXIT_PASS,runId=run_id))
    return EXIT_PASS


def cmd_complete_step(args):
    root = project_root(args.project_root)
    try: change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("complete-step","invalid_artifact","usage_error",EXIT_USAGE,errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args,'artifact_dir',None), change_name)
    step = getattr(args,'step','') or ''
    artifact = getattr(args,'artifact',None)
    state = _load_artifact(base, WORKFLOW_STATE_FILE) or {"schemaVersion":WORKFLOW_SCHEMA_VERSION,"changeName":change_name,"state":step}
    state["state"] = step
    if artifact: state.setdefault("artifacts",[]).append(artifact)
    state["updatedAt"] = utc_now()
    write_json(base / WORKFLOW_STATE_FILE, state)
    dump(json_report("complete-step","pass","completed",EXIT_PASS,step=step))
    return EXIT_PASS


def cmd_lint_response(args):
    """Lint a natural-language response against stage-specific routing rules.

    Returns exit 0 (pass) or 20 (blocked/fail) with JSON report.
    """
    # read response text
    if args.response_file:
        try:
            response = Path(args.response_file).read_text()
        except Exception as exc:
            dump(json_report("lint-response","invalid_artifact","read_error",EXIT_INVALID_ARTIFACT,errors=[str(exc)]))
            return EXIT_INVALID_ARTIFACT
    elif args.response_text:
        response = args.response_text
    else:
        # read from stdin if no explicit input
        response = sys.stdin.read()

    if not response.strip():
        dump(json_report("lint-response","invalid_artifact","empty_response",EXIT_INVALID_ARTIFACT,errors=["No response text provided"]))
        return EXIT_INVALID_ARTIFACT

    stage = args.stage
    forbidden: list[str] = []
    missing_required: list[str] = []
    detected_stage = "unknown"

    # ── pre-confirmation checks ──
    if stage == "pre-confirmation":
        detected_stage = "pre-confirmation"
        # Check for a localized "Not doing yet" section first — if present, treat as framing discipline
        has_not_doing_yet = has_not_doing_yet_section(response)

        # Always check for overt recommendations (even in clean responses)
        overt_recommendation_patterns = [
            (r'(?i)\bI recommend\b', 'I recommend'),
            (r'(?i)\bmy recommendation\b', 'my recommendation'),
            (r'(?i)\brecommended path\b', 'recommended path'),
            (r'(?i)\bbest option\b', 'best option'),
            (r'(?i)\bhighest[- ]?value\b', 'highest value'),
            (r'(?i)\brecommend\s+no[- ]build\b', 'recommend no-build'),
            (r'(?i)\brecommend\s+a?\s*smaller[- ]scope\b', 'recommend smaller-scope'),
            (r'(?i)\brecommend\s+measure[- ]first\b', 'recommend measure-first'),
        ]
        for pat, label in overt_recommendation_patterns:
            if re.search(pat, response):
                forbidden.append(label)

        # Generic forbidden terms — only flag if NOT in a "Not doing yet" section
        if not has_not_doing_yet:
            generic_patterns = [
                (r'\bno[- ]build\b', 'no-build mention'),
                (r'\bsmaller[- ]scope\b', 'smaller-scope mention'),
                (r'\bmeasure[- ]first\b', 'measure-first mention'),
                (r'(?i)\bvalue challenge\b', 'Value Challenge'),
                (r'(?i)\bproposal meaning analysis\b', 'Proposal Meaning Analysis'),
                (r'(?i)\bspec kernel\b', 'Spec Kernel'),
            ]
            for pat, label in generic_patterns:
                if re.search(pat, response, re.IGNORECASE):
                    forbidden.append(label)

        # check for "Not doing yet" section as evidence of framing-only discipline
        if not has_not_doing_yet:
            missing_required.append("Not doing yet section")

    # ── scope-selected checks ──
    elif stage == "scope-selected":
        detected_stage = "scope-selected"
        # must include all three valid decisions plus numbered choices for ergonomic input.
        required_decisions = ["confirm_scope_for_analysis", "revise_scope", "abandon_proposal"]
        for d in required_decisions:
            if d not in response:
                missing_required.append(f"decision token: {d}")
        for n in ("1", "2", "3"):
            if not re.search(rf"(?:\[{n}\]|\b{n}[.)])", response):
                missing_required.append(f"numbered choice: {n}")
        # must NOT contain approval-type decisions as valid options
        invalid_approval = ["approve_openspec_authoring", "approve_smaller_scope_openspec_authoring", "accept_no_build_recommendation"]
        for d in invalid_approval:
            if d in response:
                forbidden.append(f"Stage 5 approval token as option: {d}")
        # must not contain PMA, Spec Kernel, OpenSpec as premature content
        # Allow "Before Proposal Meaning Analysis" as framing phrase
        pma_bad = re.search(r'(?i)\bproposal meaning analysis\b', response)
        if pma_bad:
            before = response[max(0, pma_bad.start()-20):pma_bad.end()]
            if 'before' not in before.lower():
                forbidden.append("premature Proposal Meaning Analysis content")
        for pat, label in [(r'(?i)\bspec kernel\b', 'Spec Kernel'), (r'(?i)\bopenspec writing\b', 'OpenSpec writing')]:
            if re.search(pat, response):
                forbidden.append(f"premature content: {label}")

    # ── invalid-decision checks ──
    elif stage == "invalid-decision":
        detected_stage = "invalid-decision"
        # must contain rejection + valid Stage 1.7 choices
        if "reject" not in response.lower() and "invalid" not in response.lower():
            missing_required.append("rejection of invalid decision")
        for d in ["confirm_scope_for_analysis", "revise_scope", "abandon_proposal"]:
            if d not in response:
                missing_required.append(f"valid Stage 1.7 decision: {d}")
        for n in ("1", "2", "3"):
            if not re.search(rf"(?:\[{n}\]|\b{n}[.)])", response):
                missing_required.append(f"numbered choice: {n}")

    # ── grilling (value challenge / constructive disagreement) checks ──
    elif stage == "grilling":
        detected_stage = "grilling"
        has_not_doing_yet = has_not_doing_yet_section(response)

        if has_cjk(response):
            for pat, label in ENGLISH_TEMPLATE_LABELS_FOR_CJK:
                if re.search(pat, response):
                    forbidden.append(f"mixed-language template label: {label}")

        internal_reasoning_patterns = [
            (r'(?im)^\s*Refining project communication\s*$', 'internal reasoning heading: Refining project communication'),
            (r'(?im)^\s*Structuring the final response\s*$', 'internal reasoning heading: Structuring the final response'),
            (r'(?i)\bI[’\']?m considering\b', 'internal reasoning: I am considering'),
            (r'(?i)\bI need to finalize\b', 'internal reasoning: I need to finalize'),
            (r'(?i)\bI wonder if\b', 'internal reasoning: I wonder if'),
            (r'(?i)\bI think I should\b', 'internal reasoning: I think I should'),
            (r'(?i)\bI[’\']ll want to\b', 'internal reasoning: I will want to'),
        ]
        for pat, label in internal_reasoning_patterns:
            if re.search(pat, response):
                forbidden.append(label)

        # 1. Exactly one Question
        # Count explicit question marks, including CJK full-width question marks.
        # Agents must write the active grill question as an explicit question.
        total_questions = len(QUESTION_MARK_RE.findall(response))

        if total_questions == 0:
            missing_required.append("question (no question found — grilling response must include exactly one question)")
        elif total_questions > 1:
            forbidden.append(f"multiple questions ({total_questions} found — grilling response must include exactly one question)")

        # 2. My recommended answer or localized equivalent
        recommended_patterns = [
            r'(?i)my recommended answer',
            r'(?i)my recommendation',
            r'(?i)I recommend',
            r'(?i)recommended path',
            r'(?i)recommended answer',
            r'(?i)suggested approach',
            r'(?i)my suggestion',
            r'我的建議答案',
            r'建議答案',
            r'我建議',
            r'我的建議',
            r'建議做法',
            r'建議回覆',
            r'建議先',
        ]
        found_recommended = any(re.search(p, response) for p in recommended_patterns)
        if not found_recommended:
            missing_required.append("My recommended answer or localized equivalent")

        # 3. Bounded options
        bounded_option_patterns = [
            # Options: A / B style, including localized labels and full-width slash.
            r'(?i)\boptions?:?\s+A\s*[/／]\s*B',
            r'(?:選項|可選答案|有界選項|選擇)\s*[:：]?\s*A\s*[/／]\s*B',
            r'(?i)\boptions?:?\s+A[.)．、]',
            r'(?:選項|可選答案|有界選項|選擇)\s*[:：]?\s*A[.)．、]',
            r'(?i)\boptions?:?\s+\d[.)．、]',
            # A. ... B. ... style
            r'(?im)^\s*(?:A[.)．、]|B[.)．、]|1[.)．、]|2[.)．、])\s+.*(?:\n\s*(?:A[.)．、]|B[.)．、]|1[.)．、]|2[.)．、])\s+.*)*',
        ]
        option_line_count = len(re.findall(r'(?im)^\s*(?:[A-ZＡ-Ｚ][.)．、]|[0-9０-９]+[.)．、])\s+\S+', response))
        found_options = option_line_count >= 2 or any(re.search(p, response) for p in bounded_option_patterns)
        if not found_options:
            missing_required.append("bounded options (e.g., localized '選項：A / B' or 'A. ... B. ...')")

        # 4. Not doing yet section
        if not has_not_doing_yet:
            missing_required.append("Not doing yet section or localized equivalent")

        # 5. No premature content: PMA, Spec Kernel, OpenSpec writing
        # Allow these terms only when on a line that is a negative reference
        # (e.g., "- no PMA", "不進行 Spec Kernel writing", "not doing yet" section)
        lines = response.split('\n')
        premature_terms = [
            (r'(?i)\bproposal meaning analysis\b', 'Proposal Meaning Analysis'),
            (r'(?i)\bspec kernel\b', 'Spec Kernel'),
            (r'(?i)\bopenspec writing\b', 'OpenSpec writing'),
            (r'(?i)\bopenspec (?:package|scaffold)\b', 'OpenSpec scaffolding'),
        ]
        for pat, label in premature_terms:
            for line in lines:
                if re.search(pat, line):
                    # Check if this line is a negative reference (starts with - no, no, not,
                    # without, or localized equivalents such as 不/暫不/尚不).
                    if not is_negative_reference_line(line):
                        forbidden.append(f"premature content: {label}")
                        # Only flag once per label
                        break

        # Allow constructive disagreement / value challenge references (these ARE the grilling phase)
        # Do NOT flag "value challenge", "no-build", "smaller-scope" here since they are
        # legitimate content for the grilling/value-challenge phase.

    # ── digest-check ──
    elif stage == "digest-check":
        detected_stage = "digest-check"
        # must block / fail on missing digests
        if not any(tok in response.lower() for tok in ["inputdigests", "input digests", "digest", "freshness", "stale"]):
            missing_required.append("mention of missing inputDigests or freshness failure")
        if not any(tok in response.lower() for tok in ["fail", "block", "not acceptable", "reject", "invalid", "cannot accept"]):
            missing_required.append("blocking/failing language")

    errors: list[str] = []
    if forbidden:
        errors.append(f"forbidden_phrases: {', '.join(forbidden)}")
    if missing_required:
        errors.append(f"missing_required: {', '.join(missing_required)}")

    passed = not forbidden and not missing_required
    status = "pass" if passed else "fail"
    exit_code = EXIT_PASS if passed else EXIT_BLOCKED

    dump(json_report(
        "lint-response",
        "pass" if passed else "blocked",
        status,
        exit_code,
        stage=stage,
        detectedStage=detected_stage,
        forbidden=forbidden,
        missingRequired=missing_required,
    ))
    return exit_code


def cmd_next_step(args):
    root = project_root(args.project_root)
    try: change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("next-step","invalid_artifact","usage_error",EXIT_USAGE,errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args,'artifact_dir',None), change_name)
    state = _load_artifact(base, WORKFLOW_STATE_FILE)
    current = state.get("state","proposal_intake") if state else "proposal_intake"
    transitions = {"proposal_intake":"project_modeling","project_modeling":"problem_scope_framing","problem_scope_framing":"scope_closure_gate","proposal_meaning_analysis":"value_logic_closure_assessment","value_logic_closure_assessment":"logic_closure_gate","logic_closure_gate":"depends_on_gate","logic_gap_completion":"clarification_response","clarification_response":"value_logic_closure_assessment","change_value_assessment_report":"openspec_authoring_approval_gate","openspec_authoring_approval_gate":"depends_on_decision","spec_kernel":"pre_spec_gate","pre_spec_gate":"openspec_writing","openspec_writing":"explainer","explainer":"package_review","package_review":"handoff_ready","handoff_ready":"publish_closeout","publish_closeout":"terminal"}
    next_s = transitions.get(current,"unknown")
    if current == "logic_closure_gate":
        gate = _load_artifact(base, LOGIC_CLOSURE_GATE_FILE)
        next_s = "change_value_assessment_report" if (gate and gate.get("status")=="closed") else "logic_gap_completion"
    elif current == "scope_closure_gate":
        gate = _load_artifact(base, SCOPE_CLOSURE_GATE_FILE)
        next_s = "problem_scope_user_confirmation_gate" if (gate and gate.get("status") == "closed") else "problem_scope_clarification_request"
    elif current == "problem_scope_user_confirmation_gate":
        gate = _load_artifact(base, PROBLEM_SCOPE_USER_GATE_FILE)
        if gate:
            d = gate.get("decision", "")
            if d == "confirm_scope_for_analysis":
                next_s = "proposal_meaning_analysis"
            elif d == "revise_scope":
                next_s = "problem_scope_framing"
            elif d == "abandon_proposal":
                next_s = "terminal"
    elif current == "openspec_authoring_approval_gate":
        gate = _load_artifact(base, OPENSPEC_AUTHORING_APPROVAL_GATE_FILE)
        if gate:
            d = gate.get("decision","")
            next_s = "spec_kernel" if d in ("approve_openspec_authoring","approve_smaller_scope_openspec_authoring") else ("problem_scope_framing" if d=="continue_discussion" else "terminal")
    dump(json_report("next-step","pass",next_s,EXIT_PASS,current=current,next=next_s))
    return EXIT_PASS



def cmd_validate_problem_scope_framing(args):
    return _validate_artifact_cmd(args, PROBLEM_SCOPE_FRAMING_FILE, "validate-problem-scope-framing", ("intendedOutcome", "problemStatement", "targetSurface", "boundaryAssertions"))

def cmd_scope_closure_gate(args):
    root = project_root(args.project_root)
    try: change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("scope-closure-gate","invalid_artifact","usage_error",EXIT_USAGE,errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args,'artifact_dir',None), change_name)
    framing = _load_artifact(base, PROBLEM_SCOPE_FRAMING_FILE)
    if not framing:
        dump(json_report("scope-closure-gate","invalid_artifact","missing_framing",EXIT_INVALID_ARTIFACT,errors=[f"{PROBLEM_SCOPE_FRAMING_FILE} not found"]))
        return EXIT_INVALID_ARTIFACT
    blocking = []
    if not framing.get("intendedOutcome","").strip(): blocking.append("intendedOutcome")
    if not framing.get("problemStatement","").strip(): blocking.append("problemStatement")
    if not framing.get("targetSurface"): blocking.append("targetSurface")
    if not framing.get("selectedScope"): blocking.append("selectedScope")
    if not framing.get("includedChanges"): blocking.append("includedChanges")
    if "excludedChanges" not in framing: blocking.append("excludedChanges")
    if not framing.get("successSignal","").strip(): blocking.append("successSignal")
    ba = framing.get("boundaryAssertions",{})
    if not ba.get("noNoBuildRecommendation"): blocking.append("boundaryAssertions.noNoBuildRecommendation")
    if not ba.get("noValueJudgment"): blocking.append("boundaryAssertions.noValueJudgment")
    status_val = "not_closed" if blocking else "closed"
    next_step = "problem_scope_clarification_request" if blocking else "problem_scope_user_confirmation_gate"
    gate = {"schemaVersion":SCHEMA_VERSION,"changeName":change_name,"gate":"scope_closure","status":status_val,"closed":status_val=="closed","sourceFraming":PROBLEM_SCOPE_FRAMING_FILE,"inputDigests":{PROBLEM_SCOPE_FRAMING_FILE:_canonical_json_digest(framing)},"blockingFields":blocking,"nextStep":next_step,"allowedNextSteps":["problem_scope_clarification_request","problem_scope_user_confirmation_gate"],"reason":"Scope framing incomplete" if blocking else "All scope fields satisfied"}
    write_json(base / SCOPE_CLOSURE_GATE_FILE, gate)
    # Auto-populate design tree when scope is not closed (grilling loop)
    if blocking:
        design_tree = read_design_tree(base)
        if not design_tree.get("changeName"):
            design_tree = default_design_tree(change_name)
        first_blocking = blocking[0]
        question_text = f"Please provide a clear {first_blocking} description to close scope."
        design_tree = design_tree_add_question(
            design_tree, first_blocking, question_text,
            why_this_matters=f"Scope cannot be closed without a defined {first_blocking}.",
            recommended_answer=f"A concise description of {first_blocking}",
        )
        write_design_tree(base, design_tree)
        # Sync workflow-state activeGrillQuestion
        workflow_path = base / WORKFLOW_STATE_FILE
        workflow_state = read_json_optional(workflow_path)
        if workflow_state:
            active_node = next((n for n in design_tree.get("nodes", []) if n.get("questionId") == design_tree.get("activeQuestionId")), None)
            if active_node:
                workflow_state["activeGrillQuestion"] = {
                    "questionId": active_node["questionId"],
                    "field": active_node["field"],
                    "question": active_node["question"],
                    "status": active_node["status"],
                    "askedAt": active_node["askedAt"],
                }
                workflow_state["updatedAt"] = utc_now()
                write_json(workflow_path, workflow_state)
    code = EXIT_PASS if status_val == "closed" else EXIT_BLOCKED
    dump(json_report("scope-closure-gate",status_val,"generated",code,gateFile=str(base/SCOPE_CLOSURE_GATE_FILE),nextStep=next_step,blockingFields=blocking))
    return code

def cmd_validate_problem_scope_clarification_request(args):
    root = project_root(args.project_root)
    try: change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("validate-problem-scope-clarification-request","invalid_artifact","usage_error",EXIT_USAGE,errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args,'artifact_dir',None), change_name)
    artifact_path = getattr(args,'artifact',None)
    path = Path(artifact_path) if artifact_path else base / PROBLEM_SCOPE_CLARIFICATION_REQUEST_FILE
    if not path.exists():
        dump(json_report("validate-problem-scope-clarification-request","invalid_artifact","missing",EXIT_INVALID_ARTIFACT,errors=[f"{PROBLEM_SCOPE_CLARIFICATION_REQUEST_FILE} not found at {path}"]))
        return EXIT_INVALID_ARTIFACT
    data = read_json(path)
    errors = []
    # Check required top-level fields
    for field in ("blockingFields","questionsForUser","boundaryAssertions"):
        val = data
        for part in field.split("."):
            val = val.get(part) if isinstance(val,dict) else None
        if val is None or (isinstance(val,str) and not val.strip()):
            errors.append(f"missing required field: {field}")
    # Single-question enforcement: exactly one question
    questions = data.get("questionsForUser",[])
    if not isinstance(questions,list):
        errors.append("questionsForUser must be an array")
    elif len(questions) == 0:
        errors.append("questionsForUser must contain at least one question")
    elif len(questions) > 1:
        errors.append(f"questionsForUser must contain exactly one question per iteration, got {len(questions)}")
    else:
        # Validate the single question's required sub-fields
        q = questions[0]
        for sub in ("field","question","whyThisMatters","recommendedAnswer"):
            val = q.get(sub,"") if isinstance(q,dict) else None
            if not val or (isinstance(val,str) and not val.strip()):
                errors.append(f"questionsForUser[0].{sub} is required")
    if errors:
        dump(json_report("validate-problem-scope-clarification-request","invalid_artifact","validation_failed",EXIT_INVALID_ARTIFACT,errors=errors))
        return EXIT_INVALID_ARTIFACT
    digest = _canonical_json_digest(data)
    dump(json_report("validate-problem-scope-clarification-request","pass","validated",EXIT_PASS,artifactFile=str(path),digest=digest,questionsCount=len(questions)))
    return EXIT_PASS

def cmd_problem_scope_clarification_response(args):
    root = project_root(args.project_root)
    try: change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("problem-scope-clarification-response","invalid_artifact","usage_error",EXIT_USAGE,errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args,'artifact_dir',None), change_name)
    answers_raw = getattr(args,'answers','') or ''
    if not answers_raw.strip():
        dump(json_report("problem-scope-clarification-response","invalid_artifact","missing_answers",EXIT_BLOCKED,errors=["--answers required"]))
        return EXIT_BLOCKED
    try:
        answers = json.loads(answers_raw) if answers_raw.strip().startswith("[") else (json.loads(Path(answers_raw).read_text()) if Path(answers_raw).exists() else json.loads(answers_raw))
    except Exception as err:
        dump(json_report("problem-scope-clarification-response","invalid_artifact","malformed",EXIT_INVALID_ARTIFACT,errors=[str(err)]))
        return EXIT_INVALID_ARTIFACT
    req = _load_artifact(base, PROBLEM_SCOPE_CLARIFICATION_REQUEST_FILE)
    # Normalize answers to list
    answers_list = answers if isinstance(answers,list) else [answers]
    # Single-answer enforcement: exactly one answer
    if len(answers_list) == 0:
        dump(json_report("problem-scope-clarification-response","invalid_artifact","missing_answers",EXIT_INVALID_ARTIFACT,errors=["answers must contain at least one answer — got empty array"]))
        return EXIT_INVALID_ARTIFACT
    if len(answers_list) > 1:
        dump(json_report("problem-scope-clarification-response","invalid_artifact","too_many_answers",EXIT_INVALID_ARTIFACT,errors=[f"answers must contain exactly one answer per iteration, got {len(answers_list)} — use exit 40"]))
        return EXIT_INVALID_ARTIFACT
    # Validate answer field matches request question field when request exists
    if req:
        req_questions = req.get("questionsForUser",[])
        if req_questions and len(req_questions) > 0:
            expected_field = req_questions[0].get("field","") if isinstance(req_questions[0],dict) else ""
            if expected_field and isinstance(answers_list[0],dict) and answers_list[0].get("field","") != expected_field:
                dump(json_report("problem-scope-clarification-response","invalid_artifact","field_mismatch",EXIT_INVALID_ARTIFACT,errors=[f"answer field '{answers_list[0].get('field','')}' does not match request question field '{expected_field}'"]))
                return EXIT_INVALID_ARTIFACT
    artifact = {"schemaVersion":SCHEMA_VERSION,"changeName":change_name,"stage":"problem_scope_clarification_response","sourceRequest":PROBLEM_SCOPE_CLARIFICATION_REQUEST_FILE,"inputDigests":{PROBLEM_SCOPE_CLARIFICATION_REQUEST_FILE:_canonical_json_digest(req)} if req else {},"answeredBy":{"type":"human","id":"user","source":"cli"},"answers":answers_list,"readyForReframing":True,"nextStep":"problem_scope_framing"}
    write_json(base / PROBLEM_SCOPE_CLARIFICATION_RESPONSE_FILE, artifact)
    # Auto-answer the active question in the design tree
    design_tree = read_design_tree(base)
    if design_tree.get("activeQuestionId"):
        active_qid = design_tree["activeQuestionId"]
        answer_field = answers_list[0].get("field", "") if isinstance(answers_list[0], dict) else ""
        answer_value = answers_list[0].get("value", "") if isinstance(answers_list[0], dict) else str(answers_list[0])
        if answer_value and active_qid:
            try:
                design_tree = design_tree_answer_question(design_tree, active_qid, answer_field, answer_value)
                write_design_tree(base, design_tree)
            except ValueError:
                pass  # Non-blocking: design tree update is auxiliary
        # Clear workflow-state activeGrillQuestion
        workflow_path = base / WORKFLOW_STATE_FILE
        workflow_state = read_json_optional(workflow_path)
        if workflow_state:
            workflow_state["activeGrillQuestion"] = {
                "questionId": "",
                "field": "",
                "question": "",
                "status": "",
                "askedAt": "",
            }
            workflow_state["updatedAt"] = utc_now()
            write_json(workflow_path, workflow_state)
    dump(json_report("problem-scope-clarification-response","pass","captured",EXIT_PASS,artifactFile=str(base/PROBLEM_SCOPE_CLARIFICATION_RESPONSE_FILE),designTreeTotalAsked=design_tree.get("totalAsked",0),designTreeTotalAnswered=design_tree.get("totalAnswered",0)))
    return EXIT_PASS

def cmd_problem_scope_user_gate(args):
    root = project_root(args.project_root)
    try: change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("problem-scope-user-gate","invalid_artifact","usage_error",EXIT_USAGE,errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args,'artifact_dir',None), change_name)
    raw_decision = getattr(args,'decision','')
    decision = normalize_problem_scope_user_decision(raw_decision)
    if decision not in PROBLEM_SCOPE_USER_DECISIONS:
        dump(json_report("problem-scope-user-gate","invalid_artifact","invalid_decision",EXIT_USAGE,errors=[f"decision must be one of {PROBLEM_SCOPE_USER_DECISIONS}; accepted aliases: {decision_usage_message(PROBLEM_SCOPE_USER_DECISIONS, PROBLEM_SCOPE_USER_DECISION_ALIASES)}"]))
        return EXIT_USAGE
    framing = _load_artifact(base, PROBLEM_SCOPE_FRAMING_FILE)
    scope_gate = _load_artifact(base, SCOPE_CLOSURE_GATE_FILE)
    gate = {"schemaVersion":SCHEMA_VERSION,"changeName":change_name,"gate":"problem_scope_user_confirmation","sourceFraming":PROBLEM_SCOPE_FRAMING_FILE,"sourceGate":SCOPE_CLOSURE_GATE_FILE,"inputDigests":{PROBLEM_SCOPE_FRAMING_FILE:_canonical_json_digest(framing) if framing else "",SCOPE_CLOSURE_GATE_FILE:_canonical_json_digest(scope_gate) if scope_gate else ""},"scopeSummary":{"intendedOutcome":framing.get("intendedOutcome","") if framing else "","problemStatement":framing.get("problemStatement","") if framing else "","selectedScope":framing.get("selectedScope","") if framing else "","targetSurface":framing.get("targetSurface",[]) if framing else [],"includedChanges":framing.get("includedChanges",[]) if framing else [],"excludedChanges":framing.get("excludedChanges",[]) if framing else [],"successSignal":framing.get("successSignal","") if framing else ""},"decision":decision,"decidedBy":{"type":"human","id":"user"},"decisionRationale":getattr(args,'rationale','') or '','decidedAt':utc_now(),"nextStep":"proposal_meaning_analysis" if decision=="confirm_scope_for_analysis" else ("problem_scope_framing" if decision=="revise_scope" else "terminal")}
    write_json(base / PROBLEM_SCOPE_USER_GATE_FILE, gate)
    dump(json_report("problem-scope-user-gate",decision,"terminal" if decision=="abandon_proposal" else "confirmed",EXIT_PASS,gateFile=str(base/PROBLEM_SCOPE_USER_GATE_FILE)))
    return EXIT_PASS


def cmd_design_tree_add_question(args: argparse.Namespace) -> int:
    """Add a question to the design tree (durable grilling loop state)."""
    root = project_root(args.project_root)
    try:
        change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("design-tree-add-question", "invalid_artifact", "usage_error", EXIT_USAGE, errors=[str(err)]))
        return EXIT_USAGE
    if not change_name:
        dump(json_report("design-tree-add-question", "invalid_artifact", "missing_change_name", EXIT_USAGE, errors=["change-name required"]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args, 'artifact_dir', None), change_name)
    # Ensure design tree exists
    design_tree = read_design_tree(base)
    if not design_tree.get("changeName"):
        design_tree = default_design_tree(change_name)

    field = getattr(args, 'field', '') or ''
    question_text = getattr(args, 'question_text', '') or ''
    why_this_matters = getattr(args, 'why_this_matters', '') or ''
    recommended_answer = getattr(args, 'recommended_answer', '') or ''
    raw_options = getattr(args, 'options', '') or ''

    if not field or not question_text:
        dump(json_report("design-tree-add-question", "invalid_artifact", "missing_fields", EXIT_USAGE, errors=["--field and --question required"]))
        return EXIT_USAGE

    options = []
    if raw_options:
        try:
            parsed = json.loads(raw_options)
            options = parsed if isinstance(parsed, list) else [parsed]
        except json.JSONDecodeError as e:
            dump(json_report("design-tree-add-question", "invalid_artifact", "invalid_options_json", EXIT_USAGE, errors=[f"--options must be JSON array: {e}"]))
            return EXIT_USAGE

    design_tree = design_tree_add_question(
        design_tree, field, question_text,
        why_this_matters=why_this_matters,
        recommended_answer=recommended_answer,
        options=options,
    )
    write_design_tree(base, design_tree)

    # Also update workflow-state activeGrillQuestion
    workflow_path = base / WORKFLOW_STATE_FILE
    workflow_state = read_json_optional(workflow_path)
    if workflow_state:
        active_node = next((n for n in design_tree.get("nodes", []) if n.get("questionId") == design_tree.get("activeQuestionId")), None)
        if active_node:
            workflow_state["activeGrillQuestion"] = {
                "questionId": active_node["questionId"],
                "field": active_node["field"],
                "question": active_node["question"],
                "status": active_node["status"],
                "askedAt": active_node["askedAt"],
            }
            workflow_state["updatedAt"] = utc_now()
            write_json(workflow_path, workflow_state)

    dump(json_report(
        "design-tree-add-question", "pass", "question_added", EXIT_PASS,
        questionId=design_tree["activeQuestionId"],
        totalAsked=design_tree["totalAsked"],
        totalAnswered=design_tree["totalAnswered"],
    ))
    return EXIT_PASS


def cmd_design_tree_answer_question(args: argparse.Namespace) -> int:
    """Record an answer in the design tree."""
    root = project_root(args.project_root)
    try:
        change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("design-tree-answer-question", "invalid_artifact", "usage_error", EXIT_USAGE, errors=[str(err)]))
        return EXIT_USAGE
    if not change_name:
        dump(json_report("design-tree-answer-question", "invalid_artifact", "missing_change_name", EXIT_USAGE, errors=["change-name required"]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args, 'artifact_dir', None), change_name)
    design_tree = read_design_tree(base)
    if not design_tree.get("nodes"):
        dump(json_report("design-tree-answer-question", "blocked", "empty_design_tree", EXIT_BLOCKED, errors=["No questions in design tree"]))
        return EXIT_BLOCKED

    question_id = getattr(args, 'question_id', '') or ''
    field = getattr(args, 'field', '') or ''
    value = getattr(args, 'value', '') or ''

    if not value:
        dump(json_report("design-tree-answer-question", "invalid_artifact", "missing_value", EXIT_USAGE, errors=["--value required"]))
        return EXIT_USAGE

    if not question_id:
        # Auto-detect from active question
        active_id = design_tree.get("activeQuestionId", "")
        if not active_id:
            dump(json_report("design-tree-answer-question", "blocked", "no_active_question", EXIT_BLOCKED, errors=["No active question — use --question-id to specify"]))
            return EXIT_BLOCKED
        question_id = active_id

    try:
        design_tree = design_tree_answer_question(design_tree, question_id, field, value)
    except ValueError as e:
        dump(json_report("design-tree-answer-question", "blocked", "question_not_found", EXIT_BLOCKED, errors=[str(e)]))
        return EXIT_BLOCKED

    write_design_tree(base, design_tree)

    # Update workflow-state activeGrillQuestion to clear active
    workflow_path = base / WORKFLOW_STATE_FILE
    workflow_state = read_json_optional(workflow_path)
    if workflow_state:
        workflow_state["activeGrillQuestion"] = {
            "questionId": "",
            "field": "",
            "question": "",
            "status": "",
            "askedAt": "",
        }
        workflow_state["updatedAt"] = utc_now()
        write_json(workflow_path, workflow_state)

    dump(json_report(
        "design-tree-answer-question", "pass", "answer_recorded", EXIT_PASS,
        questionId=question_id,
        totalAsked=design_tree["totalAsked"],
        totalAnswered=design_tree["totalAnswered"],
    ))
    return EXIT_PASS


def cmd_design_tree_status(args: argparse.Namespace) -> int:
    """Report design tree current state."""
    root = project_root(args.project_root)
    try:
        change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("design-tree-status", "invalid_artifact", "usage_error", EXIT_USAGE, errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args, 'artifact_dir', None), change_name)
    design_tree = read_design_tree(base)
    if not design_tree.get("changeName"):
        dump(json_report("design-tree-status", "blocked", "not_initialized", EXIT_BLOCKED, errors=["Design tree not initialized; run init first"]))
        return EXIT_BLOCKED

    active_node = None
    if design_tree.get("activeQuestionId"):
        active_node = next((n for n in design_tree.get("nodes", []) if n.get("questionId") == design_tree["activeQuestionId"]), None)

    history = [n for n in design_tree.get("nodes", []) if n.get("status") == "answered"]

    dump(json_report(
        "design-tree-status", "pass", "ok", EXIT_PASS,
        designTree=design_tree,
        activeQuestion=active_node,
        historyCount=len(history),
    ))
    return EXIT_PASS


def cmd_design_tree_get_active(args: argparse.Namespace) -> int:
    """Get the active grill question."""
    root = project_root(args.project_root)
    try:
        change_name = requested_change_name(args)
    except ValueError as err:
        dump(json_report("design-tree-get-active", "invalid_artifact", "usage_error", EXIT_USAGE, errors=[str(err)]))
        return EXIT_USAGE
    base = _artifact_dir(root, getattr(args, 'artifact_dir', None), change_name)

    # First check workflow state for activeGrillQuestion
    workflow_path = base / WORKFLOW_STATE_FILE
    workflow_state = read_json_optional(workflow_path)
    if workflow_state and workflow_state.get("activeGrillQuestion", {}).get("questionId"):
        active = workflow_state["activeGrillQuestion"]
        dump(json_report(
            "design-tree-get-active", "pass", "ok", EXIT_PASS,
            activeQuestion=active,
            source="workflow-state",
        ))
        return EXIT_PASS

    # Fall back to design tree active question
    design_tree = read_design_tree(base)
    if design_tree.get("activeQuestionId"):
        active_node = next((n for n in design_tree.get("nodes", []) if n.get("questionId") == design_tree["activeQuestionId"]), None)
        if active_node:
            dump(json_report(
                "design-tree-get-active", "pass", "ok", EXIT_PASS,
                activeQuestion={
                    "questionId": active_node["questionId"],
                    "field": active_node["field"],
                    "question": active_node["question"],
                    "status": active_node["status"],
                    "askedAt": active_node["askedAt"],
                },
                source="design-tree",
            ))
            return EXIT_PASS

    dump(json_report("design-tree-get-active", "pass", "no_active_question", EXIT_PASS, activeQuestion=None))
    return EXIT_PASS


def build_parser() -> argparse.ArgumentParser:
    parser = WorkflowArgumentParser(description="Value-gated workflow helper for goal-spec")
    parser.add_argument("--json", action="store_true", help="emit JSON output (default)")
    parser.add_argument("--project-root", default=argparse.SUPPRESS, help="target project root")
    parser.add_argument("--artifact-dir", default=argparse.SUPPRESS, help="workflow artifact directory, relative to project root unless absolute")
    subparsers = parser.add_subparsers(dest="command", required=True, parser_class=WorkflowArgumentParser)

    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--json", action="store_true", default=argparse.SUPPRESS, help=argparse.SUPPRESS)
    common.add_argument("--project-root", default=argparse.SUPPRESS, help="target project root")
    common.add_argument("--artifact-dir", default=argparse.SUPPRESS, help="workflow artifact directory, relative to project root unless absolute")


    # ── Canonical flow commands ──
    intake_cmd = subparsers.add_parser("intake", parents=[common], help="capture raw proposal as proposal-intake.json")
    intake_cmd.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    intake_cmd.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    intake_cmd.add_argument("--proposal", help="raw proposal text", default="")
    intake_cmd.set_defaults(func=cmd_intake)

    v_pi = subparsers.add_parser("validate-proposal-intake", parents=[common], help="validate proposal-intake.json")
    v_pi.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    v_pi.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    v_pi.add_argument("--artifact", help="path to artifact file (default: .goal-spec/.../proposal-intake.json)")
    v_pi.set_defaults(func=cmd_validate_proposal_intake)

    v_pm = subparsers.add_parser("validate-project-model", parents=[common], help="validate project-model.json")
    v_pm.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    v_pm.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    v_pm.add_argument("--artifact", help="path to artifact file")
    v_pm.set_defaults(func=cmd_validate_project_model)

    v_pma = subparsers.add_parser("validate-proposal-meaning-analysis", parents=[common], help="validate proposal-meaning-analysis.json")
    v_pma.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    v_pma.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    v_pma.add_argument("--artifact", help="path to artifact file")
    v_pma.set_defaults(func=cmd_validate_proposal_meaning_analysis)

    v_vlca = subparsers.add_parser("validate-value-logic-closure-assessment", parents=[common], help="validate value-logic-closure-assessment.json")
    v_vlca.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    v_vlca.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    v_vlca.add_argument("--artifact", help="path to artifact file")
    v_vlca.set_defaults(func=cmd_validate_value_logic_closure_assessment)

    lcg = subparsers.add_parser("logic-closure-gate", parents=[common], help="generate logic-closure-gate.json from assessment")
    lcg.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    lcg.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    lcg.set_defaults(func=cmd_logic_closure_gate)

    v_lgb = subparsers.add_parser("validate-logic-gap-brief", parents=[common], help="validate logic-gap-brief.json")
    v_lgb.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    v_lgb.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    v_lgb.add_argument("--artifact", help="path to artifact file")
    v_lgb.set_defaults(func=cmd_validate_logic_gap_brief)

    cr = subparsers.add_parser("clarification-response", parents=[common], help="capture decision maker answers to gap questions")
    cr.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    cr.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    cr.add_argument("--answers", help="JSON answers array or path to JSON file", default="")
    cr.set_defaults(func=cmd_clarification_response)

    v_cvr = subparsers.add_parser("validate-change-value-report", parents=[common], help="validate change-value-assessment-report.json")
    v_cvr.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    v_cvr.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    v_cvr.add_argument("--artifact", help="path to artifact file")
    v_cvr.set_defaults(func=cmd_validate_change_value_report)

    ag = subparsers.add_parser("approval-gate", parents=[common], help="record OpenSpec authoring approval decision")
    ag.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    ag.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    ag.add_argument("--decision", required=True, help="approval decision; accepts canonical value, number, or short alias")
    ag.add_argument("--approved-by-type", default="human", help="approver type")
    ag.add_argument("--approved-by-id", default="user", help="approver id")
    ag.add_argument("--approved-scope", help="scope for smaller-scope approval")
    ag.add_argument("--rationale", default="", help="approval rationale")
    ag.set_defaults(func=cmd_approval_gate)

    rs = subparsers.add_parser("role-start", parents=[common], help="record role-run start")
    rs.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    rs.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    rs.add_argument("--role", required=True, help="role name (collector, judge, writer, explainer, reviewer)")
    rs.add_argument("--step", required=True, help="workflow step name")
    rs.set_defaults(func=cmd_role_start)

    rc = subparsers.add_parser("role-complete", parents=[common], help="record role-run completion")
    rc.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    rc.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    rc.add_argument("--role", required=True, help="role name")
    rc.add_argument("--step", required=True, help="workflow step name")
    rc.add_argument("--run-id", help="run id from role-start")
    rc.add_argument("--artifact", help="output artifact filename")
    rc.set_defaults(func=cmd_role_complete)

    cs = subparsers.add_parser("complete-step", parents=[common], help="record workflow step completion")
    cs.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    cs.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    cs.add_argument("--step", required=True, help="workflow state name")
    cs.add_argument("--artifact", help="output artifact filename")
    cs.set_defaults(func=cmd_complete_step)

    ns = subparsers.add_parser("next-step", parents=[common], help="compute next workflow step")
    ns.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    ns.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    ns.set_defaults(func=cmd_next_step)

    cf = subparsers.add_parser("check-freshness", parents=[common], help="check artifact digest chain freshness")
    cf.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    cf.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    cf.set_defaults(func=cmd_check_freshness)

    cnrl = subparsers.add_parser("check-no-runtime-leakage", parents=[common], help="scan for runtime-owned outputs in Stage 1 artifacts")
    cnrl.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    cnrl.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    cnrl.set_defaults(func=cmd_check_no_runtime_leakage)

    cncm = subparsers.add_parser("check-no-concrete-models", parents=[common], help="scan for concrete model IDs in Stage 1 artifacts")
    cncm.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    cncm.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    cncm.set_defaults(func=cmd_check_no_concrete_models)


    # ── Problem & Scope Confirmation Flow commands ──
    v_psf = subparsers.add_parser("validate-problem-scope-framing", parents=[common], help="validate problem-scope-framing.json")
    v_psf.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    v_psf.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    v_psf.add_argument("--artifact", help="path to artifact file")
    v_psf.set_defaults(func=cmd_validate_problem_scope_framing)

    scg = subparsers.add_parser("scope-closure-gate", parents=[common], help="generate scope-closure-gate.json from framing")
    scg.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    scg.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    scg.set_defaults(func=cmd_scope_closure_gate)

    v_pscr = subparsers.add_parser("validate-problem-scope-clarification-request", parents=[common], help="validate problem-scope-clarification-request.json")
    v_pscr.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    v_pscr.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    v_pscr.add_argument("--artifact", help="path to artifact file")
    v_pscr.set_defaults(func=cmd_validate_problem_scope_clarification_request)

    pscr = subparsers.add_parser("problem-scope-clarification-response", parents=[common], help="capture user answers to scope clarification")
    pscr.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    pscr.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    pscr.add_argument("--answers", help="JSON answers array or path to JSON file", default="")
    pscr.set_defaults(func=cmd_problem_scope_clarification_response)

    psug = subparsers.add_parser("problem-scope-user-gate", parents=[common], help="record user scope confirmation decision")
    psug.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    psug.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    psug.add_argument("--decision", required=True, help="user decision; accepts canonical value, number, or short alias")
    psug.add_argument("--rationale", default="", help="decision rationale")
    psug.set_defaults(func=cmd_problem_scope_user_gate)

    # ── Choice-Action Contract commands ──
    car = subparsers.add_parser("choice-action-request", parents=[common], help="generate a ChoiceActionRequest from a gate's decision options")
    car.add_argument("gate_name", help="gate name: problem-scope-user-gate or openspec-authoring-approval-gate")
    car.set_defaults(func=cmd_choice_action_request)

    cares = subparsers.add_parser("choice-action-result", parents=[common], help="normalize a ChoiceActionSelectionResult to a canonical gate decision")
    cares.add_argument("--gate", required=True, dest="gate_name", help="gate name: problem-scope-user-gate or openspec-authoring-approval-gate")
    cares.add_argument("--result", required=True, help="ChoiceActionSelectionResult JSON string")
    cares.set_defaults(func=cmd_choice_action_result)

    # ── Design Tree (durable grilling loop state) commands ──
    dta = subparsers.add_parser("design-tree-add-question", parents=[common], help="add a question to the durable design tree and set as active grill question")
    dta.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    dta.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    dta.add_argument("--field", required=True, help="blocking field this question addresses")
    dta.add_argument("--question", required=True, dest="question_text", help="the bounded question text")
    dta.add_argument("--why-this-matters", default="", help="why this question is blocking")
    dta.add_argument("--recommended-answer", default="", help="recommended/default answer")
    dta.add_argument("--options", default="", help="JSON array of answer options")
    dta.set_defaults(func=cmd_design_tree_add_question)

    dtans = subparsers.add_parser("design-tree-answer-question", parents=[common], help="record an answer in the design tree for the active or specified question")
    dtans.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    dtans.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    dtans.add_argument("--question-id", default="", help="question id (auto-detects active question if omitted)")
    dtans.add_argument("--field", default="", help="field being answered")
    dtans.add_argument("--value", required=True, help="answer value")
    dtans.set_defaults(func=cmd_design_tree_answer_question)

    dts = subparsers.add_parser("design-tree-status", parents=[common], help="report design tree current state (active question, history, totals)")
    dts.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    dts.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    dts.set_defaults(func=cmd_design_tree_status)

    dtga = subparsers.add_parser("design-tree-get-active", parents=[common], help="get the current active grill question")
    dtga.add_argument("change_name_arg", nargs="?", help="kebab-case change name")
    dtga.add_argument("--change-name", help="kebab-case OpenSpec change name metadata")
    dtga.set_defaults(func=cmd_design_tree_get_active)

    init = subparsers.add_parser("init", parents=[common], help="create .goal-spec artifacts")
    init.add_argument("change_name_arg", nargs="?", help="kebab-case OpenSpec change name; stores artifacts under .goal-spec/changes/<change-name>/")
    init.add_argument("--change-name", help="kebab-case OpenSpec change name metadata; must match positional name when both are provided")
    init.add_argument("--capability", help="kebab-case OpenSpec capability/spec name")
    init.add_argument("--goal", help="source user goal or intended outcome")
    init.add_argument("--force", action="store_true", help="replace existing helper artifacts")
    init.set_defaults(func=cmd_init)

    phase = subparsers.add_parser("phase", parents=[common], help="update or report phase-aware workflow state")
    phase.add_argument("change_name_arg", nargs="?", help="kebab-case change name selecting .goal-spec/changes/<change-name>/")
    phase.add_argument("--change-name", help="kebab-case OpenSpec change name metadata; must match positional name when both are provided")
    phase.add_argument("--active", required=True, help="phase id to set as active")
    phase.add_argument("--status", choices=PHASE_STATUSES, default="active", help="status to assign to the active phase")
    phase.set_defaults(func=cmd_phase)

    check = subparsers.add_parser("check", parents=[common], help="validate workflow artifacts and report gate status")
    check.add_argument("change_name_arg", nargs="?", help="kebab-case change name selecting .goal-spec/changes/<change-name>/")
    check.add_argument("--change-name", help="kebab-case OpenSpec change name metadata; must match positional name when both are provided")
    check.set_defaults(func=cmd_check)

    gate = subparsers.add_parser("gate", parents=[common], help="enforce workflow gates")
    gate.add_argument("change_name_arg", nargs="?", help="kebab-case change name selecting .goal-spec/changes/<change-name>/")
    gate.add_argument("--change-name", help="kebab-case OpenSpec change name metadata; must match positional name when both are provided")
    gate.add_argument("--pre-spec", action="store_true", help="enforce the value gate before OpenSpec writing")
    gate.add_argument("--acknowledge-assumptions", action="store_true", help="explicitly accept proceed_with_assumptions risk")
    gate.add_argument("--acknowledgement", help="acknowledgement rationale required with --acknowledge-assumptions")
    gate.add_argument("--acknowledged-by", help="identity recorded for assumption acknowledgement")
    gate.set_defaults(func=cmd_gate)

    write_spec = subparsers.add_parser("write-spec", parents=[common], help="write OpenSpec templates after the pre-spec gate passes")
    write_spec.add_argument("change_name_arg", nargs="?", help="kebab-case change name selecting .goal-spec/changes/<change-name>/")
    write_spec.add_argument("--change-name", help="kebab-case OpenSpec change name metadata; must match positional name when both are provided")
    write_spec.add_argument("--changes-dir", default="openspec/changes", help="OpenSpec changes directory, relative to project root unless absolute")
    write_spec.add_argument("--force", action="store_true", help="overwrite helper-managed OpenSpec files")
    write_spec.add_argument("--acknowledge-assumptions", action="store_true", help="explicitly accept proceed_with_assumptions risk")
    write_spec.add_argument("--acknowledgement", help="acknowledgement rationale required with --acknowledge-assumptions")
    write_spec.add_argument("--acknowledged-by", help="identity recorded for assumption acknowledgement")
    write_spec.add_argument("--legacy-value-gate", action="store_true", help="allow fallback to legacy value-gate.json when canonical artifacts are absent")
    write_spec.set_defaults(func=cmd_write_spec)

    # ── response lint ──
    lint_resp = subparsers.add_parser("lint-response", parents=[common], help="lint a natural-language response against stage-specific routing rules")
    lint_resp.add_argument("--response-text", help="plain-text response to lint")
    lint_resp.add_argument("--response-file", help="read response from file instead of --response-text")
    lint_resp.add_argument("--stage", required=True, choices=("pre-confirmation","scope-selected","invalid-decision","digest-check","grilling"), help="stage context for lint rules")
    lint_resp.set_defaults(func=cmd_lint_response)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    if not hasattr(args, "project_root"):
        args.project_root = "."
    if not hasattr(args, "artifact_dir"):
        args.artifact_dir = None
    return int(args.func(args))


if __name__ == "__main__":
    raise SystemExit(main())
