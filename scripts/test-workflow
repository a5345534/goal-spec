echo ""
echo "=============================================="
echo " agent-goal-writer-workflow test suite"
echo "=============================================="
echo ""

# Section: Init
echo "--- init ---"
run_test "creates artifacts"            test_init_creates_artifacts
run_test "refuses overwrite"            test_init_refuses_overwrite
run_test "force overwrites"             test_init_force_overwrites
run_test "invalid change-name rejected" test_init_invalid_change_name
echo ""

# Section: Check
echo "--- check ---"
run_test "missing artifact (40)"                    test_check_missing_artifact
run_test "blocked default (20)"                     test_check_blocked_default
run_test "blocked: missing success signal (40)"     test_check_blocked_missing_success_signal
run_test "blocked: missing noBuildConsidered (40)"  test_check_blocked_missing_no_build
run_test "blocked: missing goal (40)"               test_check_blocked_non_goal
run_test "blocked: missing rationale (40)"          test_check_blocked_missing_rationale
run_test "blocked: unresolved questions (20)"       test_check_blocked_unresolved_questions
run_test "pass: complete spec kernel (0)"           test_check_pass_complete
run_test "proceed_with_assumptions: no ack (30)"    test_check_proceed_no_ack
echo ""

# Section: Gate
echo "--- gate --pre-spec ---"
run_test "missing --pre-spec (64)"          test_gate_missing_pre_spec_flag
run_test "blocked status (20)"              test_gate_blocked
run_test "pass status (0)"                  test_gate_pass
run_test "proceed_with_assumptions: no ack flag (30)" test_gate_proceed_no_ack_flag
run_test "proceed_with_assumptions: with ack (0)"     test_gate_proceed_with_ack
run_test "acknowledgement without rationale (64)"     test_ack_without_rationale
echo ""

# Section: Write-spec
echo "--- write-spec ---"
run_test "fails before gate: blocked (20)"                      test_write_spec_before_gate
run_test "fails before gate: proceed_with_assumptions no ack (30)" test_write_spec_before_gate_proceed_no_ack
run_test "succeeds after pass gate (0)"                          test_write_spec_after_pass
run_test "succeeds with proceed_with_assumptions + ack (0)"      test_write_spec_proceed_with_ack
echo ""

# --- summary ---
echo "=============================================="
printf " Results: ${GREEN}%d passed${NC}" "$PASS"
if [[ "$FAIL" -gt 0 ]]; then
    printf ", ${RED}%d failed${NC}" "$FAIL"
fi
if [[ "$SKIP" -gt 0 ]]; then
    printf ", ${YELLOW}%d skipped${NC}" "$SKIP"
fi
printf " (total %d)\n" "$TOTAL"
echo "=============================================="

if [[ "$FAIL" -gt 0 ]]; then
    exit 1
fi
exit 0
