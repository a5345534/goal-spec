test_authoring_profile_abstract_model_classes() {
    python3 - <<PY
import json
from pathlib import Path
root = Path('$PROJECT_DIR')
profile_path = root / 'profiles/goal-spec-authoring-profile.json'
schema_path = root / 'schemas/goal-spec-authoring-profile.schema.json'
doc_path = root / 'docs/authoring-agent-roles.md'
profile_text = profile_path.read_text()
profile = json.loads(profile_text)
schema = json.loads(schema_path.read_text())
expected = {
    'collector': 'evidence-collector',
    'judge': 'value-judge',
    'writer': 'spec-writer',
    'explainer': 'explainer-writer',
    'reviewer': 'strict-reviewer',
}
roles = profile['roles']
assert set(roles) == set(expected), roles
for role, model_class in expected.items():
    assert roles[role]['modelClass'] == model_class, (role, roles[role]['modelClass'])
assert roles['collector']['modelClass'] != roles['judge']['modelClass']
assert profile['modelClassPolicy']['profileContainsConcreteModels'] is False
assert set(profile['modelClassPolicy']['allowedModelClasses']) == set(expected.values())
rule_ids = {rule['id']: rule for rule in profile['separationRules']}
assert rule_ids['collector-judge-separation']['required'] is True
assert rule_ids['judge-writer-separation']['required'] is True
for banned in ('openai-codex/', 'deepseek/', 'anthropic/', 'local-'):
    assert banned not in profile_text, banned
schema_roles = schema['properties']['roles']['properties']
assert schema_roles['collector']['allOf'][1]['properties']['modelClass']['const'] == 'evidence-collector'
assert schema_roles['judge']['allOf'][1]['properties']['modelClass']['const'] == 'value-judge'
doc = doc_path.read_text()
for role, model_class in expected.items():
    assert role in doc and model_class in doc, (role, model_class)
PY
}

# ── Design Tree tests ──

test_design_tree_commands_exist() {
    "$WORKFLOW" --help 2>&1 | grep -q "design-tree-add-question" || { printf "\n    ${RED}missing design-tree-add-question command${NC}\n"; return 1; }
    "$WORKFLOW" --help 2>&1 | grep -q "design-tree-answer-question" || { printf "\n    ${RED}missing design-tree-answer-question command${NC}\n"; return 1; }
    "$WORKFLOW" --help 2>&1 | grep -q "design-tree-status" || { printf "\n    ${RED}missing design-tree-status command${NC}\n"; return 1; }
    "$WORKFLOW" --help 2>&1 | grep -q "design-tree-get-active" || { printf "\n    ${RED}missing design-tree-get-active command${NC}\n"; return 1; }
    return 0
}

test_design_tree_init_creates_on_init() {
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc base ok=0
    set +e
    out=$("$WORKFLOW" init test-design-init --change-name test-design-init --capability test --goal "test" --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "init exit" || ok=1
    base="$tmp/.goal-spec/changes/test-design-init"
    [[ -f "$base/design-tree.json" ]] || { printf "\n    ${RED}missing design-tree.json after init${NC}\n"; ok=1; }
    local tree
    tree=$(cat "$base/design-tree.json")
    echo "$tree" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('schemaVersion')=='1.0', d; assert d.get('totalAsked')==0; assert d.get('totalAnswered')==0; assert d.get('activeQuestionId')==''; assert isinstance(d.get('nodes'),list) and len(d['nodes'])==0" 2>/dev/null || { printf "\n    ${RED}design-tree.json has invalid structure${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_design_tree_add_and_answer() {
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc base ok=0
    set +e
    "$WORKFLOW" init test-dt-cycle --change-name test-dt-cycle --capability test --goal "test" --project-root "$tmp" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-dt-cycle"

    # Add question
    out=$("$WORKFLOW" design-tree-add-question test-dt-cycle --field selectedScope --question "Which scope?" --why-this-matters "Need scope to proceed" --recommended-answer "minimal" --options '[{"id":"minimal","label":"Minimal"},{"id":"full","label":"Full"}]' --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "add question exit" || ok=1
    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('result')=='question_added', d.get('result')" 2>/dev/null || { printf "\n    ${RED}add question result mismatch${NC}\n"; ok=1; }

    local tree
    tree=$(cat "$base/design-tree.json")
    echo "$tree" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('totalAsked')==1; assert d.get('activeQuestionId')!=''; assert d['nodes'][0]['status']=='active'; assert d['nodes'][0]['field']=='selectedScope'" 2>/dev/null || { printf "\n    ${RED}design-tree after add question has wrong state${NC}\n"; ok=1; }

    local ws
    ws=$(cat "$base/workflow-state.json")
    echo "$ws" | python3 -c "import json,sys; d=json.load(sys.stdin); agq=d.get('activeGrillQuestion',{}); assert agq.get('questionId')!=''; assert agq.get('status')=='active'" 2>/dev/null || { printf "\n    ${RED}workflow-state missing activeGrillQuestion${NC}\n"; ok=1; }

    # Answer the question
    local active_qid
    active_qid=$(echo "$tree" | python3 -c "import json,sys; print(json.load(sys.stdin)['activeQuestionId'])")
    out=$("$WORKFLOW" design-tree-answer-question test-dt-cycle --question-id "$active_qid" --field selectedScope --value minimal --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "answer question exit" || ok=1
    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('result')=='answer_recorded', d.get('result')" 2>/dev/null || { printf "\n    ${RED}answer question result mismatch${NC}\n"; ok=1; }

    tree=$(cat "$base/design-tree.json")
    echo "$tree" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('totalAnswered')==1; assert d.get('activeQuestionId')==''; assert d['nodes'][0]['status']=='answered'; assert d['nodes'][0]['answer']['value']=='minimal'" 2>/dev/null || { printf "\n    ${RED}design-tree after answer has wrong state${NC}\n"; ok=1; }

    ws=$(cat "$base/workflow-state.json")
    echo "$ws" | python3 -c "import json,sys; d=json.load(sys.stdin); agq=d.get('activeGrillQuestion',{}); assert agq.get('questionId')=='', agq.get('questionId')" 2>/dev/null || { printf "\n    ${RED}workflow-state activeGrillQuestion not cleared${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

test_design_tree_status_reports_correctly() {
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc base ok=0
    set +e
    "$WORKFLOW" init test-dt-status --change-name test-dt-status --capability test --goal "test" --project-root "$tmp" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-dt-status"

    # No question yet status (should work even with design tree but no questions)
    out=$("$WORKFLOW" design-tree-status test-dt-status --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "design-tree-status with empty tree exit" || ok=1

    # Add question
    "$WORKFLOW" design-tree-add-question test-dt-status --field selectedScope --question "Which scope?" --project-root "$tmp" > /dev/null 2>&1

    out=$("$WORKFLOW" design-tree-status test-dt-status --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "design-tree-status with question exit" || ok=1
    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('result')=='ok'; assert d.get('activeQuestion') is not None; assert d['designTree']['totalAsked']==1" 2>/dev/null || { printf "\n    ${RED}design-tree-status wrong state${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

test_design_tree_get_active_returns_active() {
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc ok=0
    set +e
    "$WORKFLOW" init test-dt-active --change-name test-dt-active --capability test --goal "test" --project-root "$tmp" > /dev/null 2>&1

    "$WORKFLOW" design-tree-add-question test-dt-active --field selectedScope --question "Which scope?" --project-root "$tmp" > /dev/null 2>&1

    out=$("$WORKFLOW" design-tree-get-active test-dt-active --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "get-active exit" || ok=1
    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('activeQuestion') is not None; assert d['activeQuestion']['field']=='selectedScope'; assert d['activeQuestion']['status']=='active'" 2>/dev/null || { printf "\n    ${RED}get-active wrong state${NC}\n"; ok=1; }

    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('source') in ('workflow-state','design-tree'), d.get('source')" 2>/dev/null || { printf "\n    ${RED}get-active missing source${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

test_design_tree_scope_closure_auto_adds_question() {
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc base ok=0
    set +e

    "$WORKFLOW" init test-scope-dt --change-name test-scope-dt --capability test --goal "test" --project-root "$tmp" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-scope-dt"

    python3 -c 'import json; json.dump({"schemaVersion":"1.0","changeName":"test-scope-dt","intendedOutcome":"improve dashboard","problemStatement":"Dashboard is slow","targetSurface":["dashboard"],"boundaryAssertions":{"noNoBuildRecommendation":False,"noValueJudgment":False}},open("'$base'/problem-scope-framing.json","w"))' > /dev/null 2>&1

    out=$("$WORKFLOW" scope-closure-gate test-scope-dt --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 20 "$rc" "scope-closure-gate exit" || ok=1

    [[ -f "$base/design-tree.json" ]] || { printf "\n    ${RED}design-tree.json not created by scope-closure-gate${NC}\n"; ok=1; }
    local tree
    tree=$(cat "$base/design-tree.json")
    echo "$tree" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('totalAsked')>=1, d; assert d.get('activeQuestionId')!=''; assert d['nodes'][0]['status']=='active'; assert d['nodes'][0]['field'] in ('intendedOutcome','problemStatement','targetSurface','selectedScope','includedChanges','excludedChanges','successSignal','boundaryAssertions'), d['nodes'][0]['field']" 2>/dev/null || { printf "\n    ${RED}scope-closure design-tree state wrong${NC}\n"; ok=1; }

    [[ -f "$base/scope-closure-gate.json" ]] || { printf "\n    ${RED}scope-closure-gate.json not written${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

test_design_tree_clarification_response_auto_answers() {
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc base ok=0
    set +e

    "$WORKFLOW" init test-clarify-dt --change-name test-clarify-dt --capability test --goal "test" --project-root "$tmp" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-clarify-dt"

    python3 -c 'import json; json.dump({"schemaVersion":"1.0","changeName":"test-clarify-dt","intendedOutcome":"improve","problemStatement":"too slow","targetSurface":["dashboard"],"boundaryAssertions":{"noNoBuildRecommendation":False,"noValueJudgment":False}},open("'$base'/problem-scope-framing.json","w"))' > /dev/null 2>&1

    "$WORKFLOW" scope-closure-gate test-clarify-dt --project-root "$tmp" > /dev/null 2>&1

    local active_qid
    active_qid=$(python3 -c "import json; d=json.load(open('$base/design-tree.json')); print(d['activeQuestionId'])")
    [[ -n "$active_qid" ]] || { printf "\n    ${RED}no active question in design tree${NC}\n"; ok=1; }

    python3 -c 'import json; json.dump({"schemaVersion":"1.0","changeName":"test-clarify-dt","stage":"problem_scope_clarification_request","role":"judge","modelClass":"value-judge","mode":"framing_only","blockingFields":["selectedScope"],"questionsForUser":[{"field":"selectedScope","question":"Which scope?","whyThisMatters":"Need scope","recommendedAnswer":"minimal","options":[{"id":"minimal","label":"Minimal"},{"id":"full","label":"Full"}]}],"nextStep":"problem_scope_clarification_response","boundaryAssertions":{"noValueJudgment":True,"noNoBuildRecommendation":True,"noOpenSpecWriting":True,"noRuntimePlanning":True,"noConcreteModelId":True}},open("'$base'/problem-scope-clarification-request.json","w"))' > /dev/null 2>&1

    out=$("$WORKFLOW" problem-scope-clarification-response test-clarify-dt --project-root "$tmp" --answers '[{"field":"selectedScope","value":"minimal"}]' 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "clarification response exit" || ok=1

    local tree
    tree=$(cat "$base/design-tree.json")
    echo "$tree" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('totalAnswered')>=1, d; assert d['activeQuestionId']==''; answered=[n for n in d['nodes'] if n.get('status')=='answered']; assert len(answered)>=1; assert answered[0]['answer']['value']=='minimal'" 2>/dev/null || { printf "\n    ${RED}design tree not answered by clarification response${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

test_design_tree_history_is_durable() {
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc base ok=0
    set +e

    "$WORKFLOW" init test-dt-history --change-name test-dt-history --capability test --goal "test" --project-root "$tmp" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-dt-history"

    # First question and answer
    "$WORKFLOW" design-tree-add-question test-dt-history --field selectedScope --question "Which scope?" --why-this-matters "Need scope" --recommended-answer "minimal" --options '[{"id":"minimal","label":"Minimal"},{"id":"full","label":"Full"}]' --project-root "$tmp" > /dev/null 2>&1
    local qid1
    qid1=$(python3 -c "import json; d=json.load(open('$base/design-tree.json')); print(d['activeQuestionId'])")
    "$WORKFLOW" design-tree-answer-question test-dt-history --question-id "$qid1" --field selectedScope --value minimal --project-root "$tmp" > /dev/null 2>&1

    # Second question and answer
    "$WORKFLOW" design-tree-add-question test-dt-history --field successSignal --question "What success signal?" --why-this-matters "Need signal" --recommended-answer "tests pass" --options '[{"id":"tests","label":"All tests pass"},{"id":"demo","label":"Demo works"}]' --project-root "$tmp" > /dev/null 2>&1
    local qid2
    qid2=$(python3 -c "import json; d=json.load(open('$base/design-tree.json')); print(d['activeQuestionId'])")
    "$WORKFLOW" design-tree-answer-question test-dt-history --question-id "$qid2" --field successSignal --value "tests pass" --project-root "$tmp" > /dev/null 2>&1

    local tree
    tree=$(cat "$base/design-tree.json")
    echo "$tree" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('totalAsked')==2, d; assert d.get('totalAnswered')==2, d; assert d.get('activeQuestionId')==''; nodes=d['nodes']; assert len(nodes)==2; assert nodes[0]['status']=='answered'; assert nodes[1]['status']=='answered'; assert nodes[0]['answer']['value']=='minimal'; assert nodes[1]['answer']['value']=='tests pass'" 2>/dev/null || { printf "\n    ${RED}design-tree history wrong after 2 cycles${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

test_design_tree_schema_validates() {
    python3 - <<'PY'
import json

# Inline schema (replaces external schemas/design-tree.schema.json)
schema = json.loads(r'''{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Design Tree",
  "description": "Durable design-tree state for the Problem & Scope clarification grilling loop.",
  "type": "object",
  "required": ["schemaVersion", "changeName", "nodes", "activeQuestionId", "totalAsked", "totalAnswered", "updatedAt"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "changeName": { "type": "string", "minLength": 1 },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["questionId", "field", "question", "askedAt", "status"],
        "additionalProperties": false,
        "properties": {
          "questionId": { "type": "string", "minLength": 1 },
          "field": { "type": "string", "minLength": 1 },
          "question": { "type": "string", "minLength": 1 },
          "whyThisMatters": { "type": "string" },
          "recommendedAnswer": { "type": "string" },
          "options": { "type": "array", "items": { "type": "object" } },
          "askedAt": { "type": "string", "format": "date-time" },
          "answeredAt": { "type": ["string", "null"], "format": "date-time" },
          "answer": {
            "type": ["object", "null"],
            "properties": {
              "field": { "type": "string" },
              "value": { "type": "string" }
            },
            "additionalProperties": false
          },
          "status": { "enum": ["active", "answered"] }
        }
      }
    },
    "activeQuestionId": { "type": "string" },
    "totalAsked": { "type": "integer", "minimum": 0 },
    "totalAnswered": { "type": "integer", "minimum": 0 },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}''')

try:
    import jsonschema
except ImportError:
    print("jsonschema not available; skipping")
    exit(0)

empty = {
    'schemaVersion': '1.0',
    'changeName': 'test',
    'nodes': [],
    'activeQuestionId': '',
    'totalAsked': 0,
    'totalAnswered': 0,
    'updatedAt': '2026-07-01T12:00:00Z'
}
jsonschema.validate(empty, schema)

# Active question node
active = {
    'schemaVersion': '1.0',
    'changeName': 'test',
    'nodes': [{
        'questionId': 'q-001-x',
        'field': 'x',
        'question': 'Q?',
        'whyThisMatters': 'Important',
        'recommendedAnswer': 'A',
        'options': [{'id': 'a', 'label': 'A'}],
        'askedAt': '2026-07-01T12:00:00Z',
        'answeredAt': None,
        'answer': None,
        'status': 'active'
    }],
    'activeQuestionId': 'q-001-x',
    'totalAsked': 1,
    'totalAnswered': 0,
    'updatedAt': '2026-07-01T12:00:00Z'
}
jsonschema.validate(active, schema)

# Answered question node
answered = {
    'schemaVersion': '1.0',
    'changeName': 'test',
    'nodes': [{
        'questionId': 'q-001-x',
        'field': 'x',
        'question': 'Q?',
        'askedAt': '2026-07-01T12:00:00Z',
        'answeredAt': '2026-07-01T12:01:00Z',
        'answer': {'field': 'x', 'value': 'A'},
        'status': 'answered'
    }],
    'activeQuestionId': '',
    'totalAsked': 1,
    'totalAnswered': 1,
    'updatedAt': '2026-07-01T12:01:00Z'
}
jsonschema.validate(answered, schema)
print("All design tree schema validations pass")
PY
}

# --- publish-closeout test functions ---

PUBLISH_CLOSEOUT="$SCRIPT_DIR/openspec-publish-closeout"

test_publish_closeout_blocks_missing_change_dir() {
    local tmp
    tmp=$(mktemp -d)
    local out rc
    set +e
    out=$("$PUBLISH_CLOSEOUT" "nonexistent-change" --project-root "$tmp" --json 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 1 "$rc" "publish-closeout missing change dir exit" || ok=1
    assert_json_field "$out" "mode" "blocked" "mode" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_publish_closeout_non_published() {
    local tmp
    tmp=$(mktemp -d)
    local out rc change_dir

    # Scaffold a real change to get valid artifacts
    "$SCRIPT_DIR/openspec-propose" "publish-test" --project-root "$tmp" --capability "test-cap" --force --no-manifest 2>&1 > /dev/null
    "$SCRIPT_DIR/openspec-build-source-manifest" "publish-test" --project-root "$tmp" 2>&1 > /dev/null

    # Create a valid change-explainer.html since propose doesn't create one
    change_dir="$tmp/openspec/changes/publish-test"
    cat > "$change_dir/change-explainer.html" << 'HEOF'
<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>測試</title>
</head>
<body>
<section id="why"><h2>Why</h2><p>這個測試解釋了為什麼需要這個變更。</p></section>
<section id="what-changes"><h2>What Changes</h2><p>這個變更會修改哪些部分。</p></section>
<section id="before-after"><h2>Before/After</h2><p>變更前後的比較說明。</p></section>
<section id="flow"><h2>Flow</h2><p>執行流程說明概述。</p></section>
<section id="affected-surfaces"><h2>Affected Surfaces</h2><p>受影響範圍分析。</p></section>
<section id="scope-boundaries"><h2>Scope Boundaries</h2><p>範圍邊界清晰定義。</p></section>
<section id="rollout"><h2>Rollout</h2><p>逐步上線計畫。</p></section>
<section id="current-status"><h2>Current Status</h2><p>目前狀態說明。</p></section>
</body>
</html>
HEOF

    set +e
    out=$("$PUBLISH_CLOSEOUT" "publish-test" --project-root "$tmp" --non-published --skip-browser-layout --json 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "publish-closeout non-published exit" || ok=1
    assert_json_field "$out" "mode" "non_published" "mode" || ok=1
    rm -rf "$tmp"
    return $ok
}

