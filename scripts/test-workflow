    assert_json_field "$out" "exitCodeName" "blocked" "exitCodeName" || ok=1
    assert_json_field "$out" "result" "blocked" "result" || ok=1
    # Verify pre-spec-gate.json was written
    [[ -f "$tmp/.writer-workflow/pre-spec-gate.json" ]] || { printf "\n    ${RED}missing pre-spec-gate.json${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_gate_pass() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "gate-pass" --capability "cap" > /dev/null 2>&1
    filled_gate_pass "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" gate --pre-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "gate pass exit" || ok=1
    assert_json_field "$out" "exitCodeName" "pass" "exitCodeName" || ok=1
    assert_json_field "$out" "allowed" "True" "allowed" || ok=1
    # Verify pre-spec-gate.json and status.json were written
    [[ -f "$tmp/.writer-workflow/pre-spec-gate.json" ]] || { printf "\n    ${RED}missing pre-spec-gate.json${NC}\n"; ok=1; }
    [[ -f "$tmp/.writer-workflow/status.json" ]] || { printf "\n    ${RED}missing status.json${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_write_spec_before_gate() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" > /dev/null 2>&1
    filled_gate_blocked "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" write-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 20 "$rc" "write-spec before gate exit" || ok=1
    assert_json_field "$out" "exitCodeName" "blocked" "exitCodeName" || ok=1
    # Verify write-spec-status.json was written
    [[ -f "$tmp/.writer-workflow/write-spec-status.json" ]] || { printf "\n    ${RED}missing write-spec-status.json${NC}\n"; ok=1; }
    # Ensure no OpenSpec artifacts were written
    [[ ! -d "$tmp/openspec" ]] || { printf "\n    ${RED}unexpected OpenSpec dir${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_write_spec_before_gate_proceed_no_ack() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "ws-no-ack" --capability "cap" > /dev/null 2>&1
    filled_gate_proceed "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" write-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 30 "$rc" "write-spec proceed no ack exit" || ok=1
    assert_json_field "$out" "exitCodeName" "acknowledgement_required" "exitCodeName" || ok=1
    [[ ! -d "$tmp/openspec" ]] || { printf "\n    ${RED}unexpected OpenSpec dir${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_write_spec_after_pass() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "ws-pass" --capability "ws-cap" > /dev/null 2>&1
    filled_gate_pass "$tmp" "ws-pass" "ws-cap" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" write-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "write-spec after pass exit" || ok=1
    assert_json_field "$out" "exitCodeName" "pass" "exitCodeName" || ok=1
    assert_json_field "$out" "result" "written" "result" || ok=1
    # Verify OpenSpec files were written
    [[ -f "$tmp/openspec/changes/ws-pass/proposal.md" ]] || { printf "\n    ${RED}missing proposal.md${NC}\n"; ok=1; }
    [[ -f "$tmp/openspec/changes/ws-pass/design.md" ]] || { printf "\n    ${RED}missing design.md${NC}\n"; ok=1; }
    [[ -f "$tmp/openspec/changes/ws-pass/tasks.md" ]] || { printf "\n    ${RED}missing tasks.md${NC}\n"; ok=1; }
    [[ -f "$tmp/openspec/changes/ws-pass/specs/ws-cap/spec.md" ]] || { printf "\n    ${RED}missing spec.md${NC}\n"; ok=1; }
    [[ -f "$tmp/openspec/changes/ws-pass/source-manifest.json" ]] || { printf "\n    ${RED}missing source-manifest.json${NC}\n"; ok=1; }
    [[ -f "$tmp/openspec/changes/ws-pass/.openspec.yaml" ]] || { printf "\n    ${RED}missing .openspec.yaml${NC}\n"; ok=1; }
    # Verify proposal includes success signal from value gate
    grep -q "All test scenarios pass" "$tmp/openspec/changes/ws-pass/proposal.md" \
        || { printf "\n    ${RED}proposal.md missing success signal${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_write_spec_proceed_with_ack() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "ws-ack" --capability "ws-ack-cap" > /dev/null 2>&1
    filled_gate_proceed "$tmp" "ws-ack" "ws-ack-cap" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" write-spec --project-root "$tmp" \
        --acknowledge-assumptions --acknowledgement "Proceed accepted for write-spec test." 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "write-spec proceed with ack exit" || ok=1
    assert_json_field "$out" "result" "written" "result" || ok=1
    # Verify proposal marks proceed_with_assumptions
    grep -q "proceed_with_assumptions" "$tmp/openspec/changes/ws-ack/proposal.md" \
        || { printf "\n    ${RED}proposal does not reflect proceed_with_assumptions${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_gate_missing_pre_spec_flag() {
    local tmp
    tmp=$(mktemp -d)
    local out rc
    set +e
    out=$("$WORKFLOW" gate --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 64 "$rc" "gate without --pre-spec exit" || ok=1
    assert_json_field "$out" "result" "usage_error" "result" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_ack_without_rationale() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "bad-ack" --capability "cap" > /dev/null 2>&1
    filled_gate_proceed "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" gate --pre-spec --project-root "$tmp" \
        --acknowledge-assumptions --acknowledgement "" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 64 "$rc" "ack without rationale exit" || ok=1
    rm -rf "$tmp"
    return $ok
}

