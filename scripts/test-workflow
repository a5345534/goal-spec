# ── Problem & Scope Confirmation Flow tests ──

test_scope_uncertainty_blocks_meaning_analysis() {
    # Scope uncertainty → not_closed, proposal-meaning-analysis blocked
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    "$WORKFLOW" intake test-scope-uncertain --project-root "$tmp" --proposal "I want to make this more complete but not sure about scope" > /dev/null 2>&1
    python3 -c "
import json, os
base='$tmp/.goal-spec/changes/test-scope-uncertain'
os.makedirs(base,exist_ok=True)
pm={'schemaVersion':'1.0','changeName':'test-scope-uncertain','role':'collector','modelClass':'evidence-collector','projectPurpose':'test','stageBoundary':{'ownedStage':'Stage 1','mustNotDo':[]},'sourceRefs':['SKILL.md']}
with open(f'{base}/project-model.json','w') as f: json.dump(pm,f)
" > /dev/null 2>&1
    # Create framing with uncertainty (no selectedScope)
    "$WORKFLOW" next-step test-scope-uncertain --project-root "$tmp" > /dev/null 2>&1
    python3 -c "
import json, os
base='$tmp/.goal-spec/changes/test-scope-uncertain'
framing={'schemaVersion':'1.0','changeName':'test-scope-uncertain','stage':'problem_scope_framing','role':'judge','modelClass':'value-judge','mode':'framing_only','intendedOutcome':'Make it complete','problemStatement':'Scope unclear','improvementIntent':True,'targetSurface':['SKILL.md'],'scopeUncertainty':True,'scopeCandidates':[{'id':'minimal','label':'Minimal','description':'x','includedChanges':['a'],'excludedChanges':['b'],'successSignal':'test','tradeOff':'small'}],'selectedScope':'','includedChanges':[],'excludedChanges':[],'successSignal':'','blockingQuestions':[{'field':'selectedScope','question':'Which scope?','options':['minimal','standard','full']}],'scopeClosed':False,'boundaryAssertions':{'noValueJudgment':True,'noNoBuildRecommendation':True,'noOpenSpecWriting':True,'noRuntimePlanning':True,'noConcreteModelId':True}}
with open(f'{base}/problem-scope-framing.json','w') as f: json.dump(framing,f)
" > /dev/null 2>&1
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" scope-closure-gate test-scope-uncertain --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 20 "$rc" "scope uncertainty gate exit" || ok=1
    assert_json_field "$out" "status" "not_closed" "status" || ok=1
    assert_json_field "$out" "nextStep" "problem_scope_clarification_request" "nextStep" || ok=1
    # Proposal meaning analysis must be blocked
    set +e
    out2=$("$WORKFLOW" validate-proposal-meaning-analysis test-scope-uncertain --project-root "$tmp" 2>&1)
    rc2=$?
    set -e
    assert_exit 40 "$rc2" "proposal-meaning-analysis blocked exit" 2>/dev/null || true
    rm -rf "$tmp"
    return $ok
}

test_clarification_request_response_separation() {
    # Clarification request/response are separate, with bounded questions
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    "$WORKFLOW" intake test-clarify --project-root "$tmp" --proposal "Test" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-clarify"
    mkdir -p "$base"
    python3 -c "
import json
framing={'schemaVersion':'1.0','changeName':'test-clarify','stage':'problem_scope_framing','role':'judge','modelClass':'value-judge','mode':'framing_only','intendedOutcome':'x','problemStatement':'x','targetSurface':['a'],'scopeCandidates':[],'selectedScope':'','includedChanges':[],'excludedChanges':[],'successSignal':'','blockingQuestions':[{'field':'selectedScope','question':'Which?','options':['minimal','full']}],'boundaryAssertions':{'noValueJudgment':True,'noNoBuildRecommendation':True,'noOpenSpecWriting':True,'noRuntimePlanning':True,'noConcreteModelId':True}}
with open(f'{base}/problem-scope-framing.json','w') as f: json.dump(framing,f)
" > /dev/null 2>&1
    "$WORKFLOW" scope-closure-gate test-clarify --project-root "$tmp" > /dev/null 2>&1
    python3 -c "
import json
req={'schemaVersion':'1.0','changeName':'test-clarify','stage':'problem_scope_clarification_request','role':'judge','modelClass':'value-judge','mode':'framing_only','blockingFields':['selectedScope'],'questionsForUser':[{'field':'selectedScope','question':'Which scope?','options':[{'id':'minimal','label':'Minimal'},{'id':'full','label':'Full'}]}],'nextStep':'problem_scope_clarification_response','boundaryAssertions':{'noValueJudgment':True,'noNoBuildRecommendation':True,'noOpenSpecWriting':True,'noRuntimePlanning':True,'noConcreteModelId':True}}
with open(f'{base}/problem-scope-clarification-request.json','w') as f: json.dump(req,f)
" > /dev/null 2>&1
    # Validate request
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" validate-problem-scope-clarification-request test-clarify --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    [[ -f "$base/problem-scope-clarification-request.json" ]] || { printf "\n    ${RED}missing clarification request${NC}\n"; ok=1; }
    # Record response
    "$WORKFLOW" problem-scope-clarification-response test-clarify --project-root "$tmp" --answers '[{"field":"selectedScope","value":"full","rawAnswer":"full"}]' > /dev/null 2>&1
    # Verify response exists as separate artifact
    [[ -f "$base/problem-scope-clarification-response.json" ]] || { printf "\n    ${RED}missing clarification response${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

