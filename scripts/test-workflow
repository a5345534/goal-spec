test_lint_response_grilling_cjk_localized_pass() {
    # Traditional Chinese grilling response with localized labels and CJK question mark must pass.
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" lint-response --stage grilling --response-text "問題與範圍追問

- 期望成果：建立新的 OpenSpec change，但尚未知道實際產品或技術變更。
- 改善意圖：true
- 範圍不確定：true
- 目前基準／來源脈絡：目前工作目錄是 /tmp/example；尚未收到變更目標。

設計樹狀態
- 已解決分支：使用 goal-spec skill。
- 開放阻塞分支：raw-proposal — 原始變更目標。

阻塞釐清（只能 1 題）
- 問題：這個新 OpenSpec change 想要達成的原始目標是什麼？
- 為什麼重要：沒有原始目標就無法建立問題與範圍框架。
- 我的建議答案：請用 2–5 句描述目前問題、想改善的結果、已知受影響 repo/module。
- 選項：
  A. 新功能或能力：描述使用者或系統需要能做什麼
  B. Bugfix 或行為修正：描述現在錯在哪、期望行為是什麼
  C. 架構或治理決策：描述要標準化或改變的邊界或流程

暫不處理：
- 不進行 Proposal Meaning Analysis
- 不撰寫 Spec Kernel 或 OpenSpec writing
- 不做價值判斷" --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "lint grilling cjk localized pass exit" || ok=1
    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('result')=='pass', d" 2>/dev/null || { printf "\n    ${RED}localized CJK grilling response must pass${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

