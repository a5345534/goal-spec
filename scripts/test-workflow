# --- test functions (each returns 0 on success, 1 on failure) ---

test_init_creates_artifacts() {
    local tmp
    tmp=$(mktemp -d)
    local out rc
    set +e
    out=$("$WORKFLOW" init --project-root "$tmp" --change-name "init-test" --capability "test-cap" --goal "Init test." 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "init exit" || ok=1
    assert_json_field "$out" "status" "blocked" "status" || ok=1
    assert_json_field "$out" "result" "initialized" "result" || ok=1

    [[ -f "$tmp/.writer-workflow/value-gate.json" ]] || { printf "\n    ${RED}missing value-gate.json${NC}\n"; ok=1; }
    [[ -f "$tmp/.writer-workflow/spec-kernel.md" ]] || { printf "\n    ${RED}missing spec-kernel.md${NC}\n"; ok=1; }
    [[ -f "$tmp/.writer-workflow/README.md" ]] || { printf "\n    ${RED}missing README.md${NC}\n"; ok=1; }
    [[ -f "$tmp/.writer-workflow/status.json" ]] || { printf "\n    ${RED}missing status.json${NC}\n"; ok=1; }

    # Validate value-gate.json schema
    python3 -c "
import json
with open('$tmp/.writer-workflow/value-gate.json') as f:
    d = json.load(f)
assert d['schemaVersion'] == '1.0'
assert d['status'] == 'blocked'
assert d['changeName'] == 'init-test'
assert d['capability'] == 'test-cap'
assert d['goal'] == 'Init test.'
assert 'valueFrame' in d
assert 'decision' in d
print('OK')
" > /dev/null 2>&1 || { printf "\n    ${RED}value-gate.json schema invalid${NC}\n"; ok=1; }

    rm -rf "$tmp"
    return $ok
}

test_init_refuses_overwrite() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "ow-test" > /dev/null 2>&1
    local out rc
    set +e
    out=$("$WORKFLOW" init --project-root "$tmp" --change-name "ow-test" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 40 "$rc" "init overwrite exit" || ok=1
    assert_json_field "$out" "exitCodeName" "invalid_artifact" "exitCodeName" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_init_force_overwrites() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "force-old" > /dev/null 2>&1
    local out rc
    set +e
    out=$("$WORKFLOW" init --project-root "$tmp" --change-name "force-new" --force 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "init force exit" || ok=1
    # Verify changeName was updated
    python3 -c "
import json
with open('$tmp/.writer-workflow/value-gate.json') as f:
    d = json.load(f)
assert d['changeName'] == 'force-new'
print('OK')
" > /dev/null 2>&1 || { printf "\n    ${RED}force did not update changeName${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_init_invalid_change_name() {
    local tmp
    tmp=$(mktemp -d)
    local out rc
    set +e
    out=$("$WORKFLOW" init --project-root "$tmp" --change-name "Bad Name!" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 64 "$rc" "bad change-name exit" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_check_missing_artifact() {
    local tmp
    tmp=$(mktemp -d)
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 40 "$rc" "missing artifact exit" || ok=1
    assert_json_field "$out" "exitCodeName" "invalid_artifact" "exitCodeName" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_check_blocked_default() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" > /dev/null 2>&1
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 20 "$rc" "blocked default exit" || ok=1
    assert_json_field "$out" "exitCodeName" "blocked" "exitCodeName" || ok=1
    assert_json_field "$out" "result" "blocked" "result" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_check_blocked_missing_success_signal() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" > /dev/null 2>&1
    gapped_success_signal "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    # Should be invalid_artifact (40) because status=pass but fields are placeholder
    assert_exit 40 "$rc" "missing success signal exit" || ok=1
    assert_json_field "$out" "exitCodeName" "invalid_artifact" "exitCodeName" || ok=1
    # Verify the error references the missing field
    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert any('successSignal' in e or 'success signal' in e.lower() for e in d.get('errors',[]))" > /dev/null 2>&1 \
        || { printf "\n    ${RED}error does not mention missing success signal${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

