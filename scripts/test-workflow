test_user_confirm_unlocks_meaning_analysis() {
    # User confirm → proposal meaning analysis allowed
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    "$WORKFLOW" intake test-confirm --project-root "$tmp" --proposal "Test" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-confirm"
    mkdir -p "$base"
    python3 -c "
import json
framing={'schemaVersion':'1.0','changeName':'test-confirm','stage':'problem_scope_framing','role':'judge','modelClass':'value-judge','mode':'framing_only','intendedOutcome':'x','problemStatement':'x','targetSurface':['a'],'scopeCandidates':[],'selectedScope':'full','includedChanges':['a'],'excludedChanges':['b'],'successSignal':'pass','blockingQuestions':[],'scopeClosed':True,'boundaryAssertions':{'noValueJudgment':True,'noNoBuildRecommendation':True,'noOpenSpecWriting':True,'noRuntimePlanning':True,'noConcreteModelId':True}}
with open(f'{base}/problem-scope-framing.json','w') as f: json.dump(framing,f)
" > /dev/null 2>&1
    "$WORKFLOW" scope-closure-gate test-confirm --project-root "$tmp" > /dev/null 2>&1
    "$WORKFLOW" problem-scope-user-gate test-confirm --project-root "$tmp" --decision confirm_scope_for_analysis > /dev/null 2>&1
    # Create minimal proposal-meaning-analysis for validation
    python3 -c "
import json
pma={'schemaVersion':'1.0','changeName':'test-confirm','role':'judge','modelClass':'value-judge','proposalSummary':'x','meaningToProject':{'classification':'logic_enhancement','reason':'x'},'logicDuplicatePoints':[],'logicConflictPoints':[],'logicEnhancementPoints':[],'logicGapPoints':[],'boundaryFit':{'status':'satisfied','reason':'x'},'sourceScopeUserGate':'problem-scope-user-gate.json','confirmedScopeSummary':{'intendedOutcome':'x','problemStatement':'x','selectedScope':'full','includedChanges':['a'],'excludedChanges':['b'],'successSignal':'pass'}}
with open(f'{base}/proposal-meaning-analysis.json','w') as f: json.dump(pma,f)
" > /dev/null 2>&1
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" validate-proposal-meaning-analysis test-confirm --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    [[ "$rc" -eq 0 ]] || [[ "$rc" -eq 20 ]] && true || ok=1  # 0=pass or 20=content-blocked both acceptable
    rm -rf "$tmp"
    return $ok
}

