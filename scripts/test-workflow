    base="$tmp/.goal-spec/changes/test-valid-single"
    mkdir -p "$base"
    python3 -c 'import json; framing={"schemaVersion":"1.0","changeName":"test-valid-single","stage":"problem_scope_framing","role":"judge","modelClass":"value-judge","mode":"framing_only","intendedOutcome":"x","problemStatement":"x","targetSurface":["a"],"scopeCandidates":[],"selectedScope":"","includedChanges":[],"excludedChanges":[],"successSignal":"","blockingQuestions":[{"field":"selectedScope","question":"Which?","options":["minimal","full"]}],"boundaryAssertions":{"noValueJudgment":True,"noNoBuildRecommendation":True,"noOpenSpecWriting":True,"noRuntimePlanning":True,"noConcreteModelId":True}}; json.dump(framing,open("'"$base"'/problem-scope-framing.json","w"))' > /dev/null 2>&1
    "$WORKFLOW" scope-closure-gate test-valid-single --project-root "$tmp" > /dev/null 2>&1
    # Valid single question with whyThisMatters and recommendedAnswer
    python3 -c 'import json; req={"schemaVersion":"1.0","changeName":"test-valid-single","stage":"problem_scope_clarification_request","role":"judge","modelClass":"value-judge","mode":"framing_only","blockingFields":["selectedScope"],"questionsForUser":[{"field":"selectedScope","question":"Which scope?","whyThisMatters":"Cannot proceed without a clear scope selection","recommendedAnswer":"minimal — smallest valuable change","options":[{"id":"minimal","label":"Minimal"},{"id":"full","label":"Full"}]}],"nextStep":"problem_scope_clarification_response","boundaryAssertions":{"noValueJudgment":True,"noNoBuildRecommendation":True,"noOpenSpecWriting":True,"noRuntimePlanning":True,"noConcreteModelId":True}}; json.dump(req,open("'"$base"'/problem-scope-clarification-request.json","w"))' > /dev/null 2>&1
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" validate-problem-scope-clarification-request test-valid-single --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "valid single-question request must exit 0" || ok=1
    # Also verify the response for a single answer passes
    set +e
    out=$("$WORKFLOW" problem-scope-clarification-response test-valid-single --project-root "$tmp" --answers '[{"field":"selectedScope","value":"full"}]' 2>&1)
    rc=$?
    set -e
    assert_exit 0 "$rc" "valid single-answer response must exit 0" || ok=1
    [[ -f "$base/problem-scope-clarification-response.json" ]] || { printf "\n    ${RED}missing clarification response${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

