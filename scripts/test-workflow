    set -e
    assert_exit 0 "$rc" "abandon proposal next-step exit" || ok=1
    assert_json_field "$out" "next" "terminal" "next" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_scope_gate_commands_exist() {
    # New commands are present
    local ok=0
    "$WORKFLOW" --help 2>&1 | grep -q "scope-closure-gate" || { printf "\n    ${RED}missing scope-closure-gate command${NC}\n"; ok=1; }
    "$WORKFLOW" --help 2>&1 | grep -q "problem-scope-user-gate" || { printf "\n    ${RED}missing problem-scope-user-gate command${NC}\n"; ok=1; }
    return $ok
}

test_approval_decisions_rejected_at_scope_gate() {
    # approval-type decisions rejected at problem-scope-user-gate
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    "$WORKFLOW" intake test-badgate --project-root "$tmp" --proposal "Test" > /dev/null 2>&1
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" problem-scope-user-gate test-badgate --project-root "$tmp" --decision approve_openspec_authoring 2>&1)
    rc=$?
    set -e
    assert_exit 64 "$rc" "approval decision rejected at scope gate exit" 2>/dev/null || ok=1
    rm -rf "$tmp"
    return $ok
}

test_framing_only_no_no_build() {
    # Framing-only mode has boundary assertions preventing no-build
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    "$WORKFLOW" intake test-framing --project-root "$tmp" --proposal "I want to improve this" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-framing"
    mkdir -p "$base"
    python3 -c "
import json
framing={'schemaVersion':'1.0','changeName':'test-framing','stage':'problem_scope_framing','role':'judge','modelClass':'value-judge','mode':'framing_only','intendedOutcome':'x','problemStatement':'x','improvementIntent':True,'targetSurface':['a'],'scopeUncertainty':True,'scopeCandidates':[{'id':'full','label':'Full','description':'x','includedChanges':['a'],'excludedChanges':[],'successSignal':'pass','tradeOff':'big'}],'selectedScope':'','includedChanges':[],'excludedChanges':[],'successSignal':'','blockingQuestions':[{'field':'selectedScope','question':'Which?','options':['full']}],'scopeClosed':False,'boundaryAssertions':{'noValueJudgment':True,'noNoBuildRecommendation':True,'noOpenSpecWriting':True,'noRuntimePlanning':True,'noConcreteModelId':True}}
with open(f'{base}/problem-scope-framing.json','w') as f: json.dump(framing,f)
" > /dev/null 2>&1
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" validate-problem-scope-framing test-framing --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    [[ -f "$base/problem-scope-framing.json" ]] || { printf "\n    ${RED}framing artifact missing${NC}\n"; ok=1; }
    :
    rm -rf "$tmp"
    return $ok
}

test_authoring_profile_abstract_model_classes() {
    python3 - <<PY
import json
from pathlib import Path
root = Path('$PROJECT_DIR')
profile_path = root / 'profiles/goal-spec-authoring-profile.json'
schema_path = root / 'schemas/goal-spec-authoring-profile.schema.json'
doc_path = root / 'docs/authoring-agent-roles.md'
profile_text = profile_path.read_text()
profile = json.loads(profile_text)
schema = json.loads(schema_path.read_text())
expected = {
    'collector': 'evidence-collector',
    'judge': 'value-judge',
    'writer': 'spec-writer',
    'explainer': 'explainer-writer',
    'reviewer': 'strict-reviewer',
}
roles = profile['roles']
assert set(roles) == set(expected), roles
for role, model_class in expected.items():
    assert roles[role]['modelClass'] == model_class, (role, roles[role]['modelClass'])
assert roles['collector']['modelClass'] != roles['judge']['modelClass']
assert profile['modelClassPolicy']['profileContainsConcreteModels'] is False
assert set(profile['modelClassPolicy']['allowedModelClasses']) == set(expected.values())
rule_ids = {rule['id']: rule for rule in profile['separationRules']}
assert rule_ids['collector-judge-separation']['required'] is True
assert rule_ids['judge-writer-separation']['required'] is True
for banned in ('openai-codex/', 'deepseek/', 'anthropic/', 'local-'):
    assert banned not in profile_text, banned
schema_roles = schema['properties']['roles']['properties']
assert schema_roles['collector']['allOf'][1]['properties']['modelClass']['const'] == 'evidence-collector'
assert schema_roles['judge']['allOf'][1]['properties']['modelClass']['const'] == 'value-judge'
doc = doc_path.read_text()
for role, model_class in expected.items():
    assert role in doc and model_class in doc, (role, model_class)
PY
}

