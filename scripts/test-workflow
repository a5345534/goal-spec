test_check_blocked_unresolved_questions() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" > /dev/null 2>&1
    filled_gate_blocked "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 20 "$rc" "blocked with questions exit" || ok=1
    assert_json_field "$out" "exitCodeName" "blocked" "exitCodeName" || ok=1
    # Verify blockers are in output
    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d['blockers'] != []" > /dev/null 2>&1 \
        || { printf "\n    ${RED}blockers list is empty${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_check_pass_complete() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "complete-test" --capability "cap" --goal "Complete." > /dev/null 2>&1
    filled_gate_pass "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "pass complete exit" || ok=1
    assert_json_field "$out" "exitCodeName" "pass" "exitCodeName" || ok=1
    assert_json_field "$out" "result" "pass" "result" || ok=1
    assert_json_field "$out" "allowed" "True" "allowed" || ok=1
    # checks should include pre_spec_artifact pass
    echo "$out" | python3 -c "
import json,sys
d=json.load(sys.stdin)
checks = d.get('checks',[])
assert any(c['name']=='pre_spec_artifact' and c['status']=='pass' for c in checks)
" > /dev/null 2>&1 || { printf "\n    ${RED}pre_spec_artifact check not passing${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_check_proceed_no_ack() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "proceed-test" --capability "cap" > /dev/null 2>&1
    filled_gate_proceed "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" check --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 30 "$rc" "proceed no ack exit" || ok=1
    assert_json_field "$out" "exitCodeName" "acknowledgement_required" "exitCodeName" || ok=1
    assert_json_field "$out" "result" "acknowledgement_required" "result" || ok=1
    assert_json_field "$out" "acknowledgementRequired" "True" "acknowledgementRequired" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_gate_proceed_with_ack() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "ack-test" --capability "cap" > /dev/null 2>&1
    filled_gate_proceed "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" gate --pre-spec --project-root "$tmp" \
        --acknowledge-assumptions --acknowledgement "Accepted for testing." 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 0 "$rc" "proceed with ack exit" || ok=1
    assert_json_field "$out" "exitCodeName" "pass" "exitCodeName" || ok=1
    assert_json_field "$out" "result" "pass" "result" || ok=1
    # Verify the value-gate.json was updated with acknowledgement
    python3 -c "
import json
with open('$tmp/.writer-workflow/value-gate.json') as f:
    d = json.load(f)
assert d['acknowledgement']['accepted'] == True
assert d['acknowledgement']['rationale'] == 'Accepted for testing.'
print('OK')
" > /dev/null 2>&1 || { printf "\n    ${RED}acknowledgement not persisted${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

test_gate_proceed_no_ack_flag() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" --change-name "no-ack-flag" --capability "cap" > /dev/null 2>&1
    filled_gate_proceed "$tmp" > "$tmp/.writer-workflow/value-gate.json"
    local out rc
    set +e
    out=$("$WORKFLOW" gate --pre-spec --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    local ok=0
    assert_exit 30 "$rc" "gate proceed no ack flag exit" || ok=1
    assert_json_field "$out" "exitCodeName" "acknowledgement_required" "exitCodeName" || ok=1
    rm -rf "$tmp"
    return $ok
}

test_gate_blocked() {
    local tmp
    tmp=$(mktemp -d)
    "$WORKFLOW" init --project-root "$tmp" > /dev/null 2>&1
    filled_gate_blocked "$tmp" > "$tmp/.writer-workflow/value-gate.json"
