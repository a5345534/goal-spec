test_continue_discussion_routes_to_framing() {
    # Verify next-step transition: openspec_authoring_approval_gate with continue_discussion → problem_scope_framing
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    "$WORKFLOW" intake test-contdisc --project-root "$tmp" --proposal "Test" > /dev/null 2>&1
    base="$tmp/.goal-spec/changes/test-contdisc"
    mkdir -p "$base"
    # Create approval gate with continue_discussion
    python3 -c "
import json
ag={'schemaVersion':'1.0','changeName':'test-contdisc','gate':'openspec_authoring_approval','decision':'continue_discussion','sourceReport':'cvr.json','inputDigests':{},'approvedBy':{'type':'human','id':'user'},'approvalRationale':'test','decidedAt':'2026-06-23T00:00:00Z','readyForSpecKernel':False}
with open('$base/openspec-authoring-approval-gate.json','w') as f: json.dump(ag,f)
# Set workflow state to openspec_authoring_approval_gate
state={'schemaVersion':'1.1','changeName':'test-contdisc','state':'openspec_authoring_approval_gate'}
with open('$base/workflow-state.json','w') as f: json.dump(state,f)
" > /dev/null 2>&1
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" next-step test-contdisc --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    # Accept either problem_scope_framing (new behavior) or old value_logic_closure_assessment
    nxt=$(echo "$out" | python3 -c "import sys,json; print(json.load(sys.stdin).get('next',''))")
    if [ "$nxt" = "problem_scope_framing" ]; then
        ok=0
    else
        printf "\n    ${RED}next: expected 'problem_scope_framing', got '%s'${NC}\n" "$nxt"
        ok=1
    fi
    rm -rf "$tmp"
    return $ok
}

test_lint_response_pre_confirmation_blocks_no_build() {
    # pre-confirmation response containing no-build recommendation must fail lint
    local tmp
    tmp=$(mktemp -d)
    git -C "$tmp" init -q
    local out rc ok=0
    set +e
    out=$("$WORKFLOW" lint-response --stage pre-confirmation --response-text "I recommend no-build for this feature. The existing functionality already handles it." --project-root "$tmp" 2>&1)
    rc=$?
    set -e
    assert_exit 20 "$rc" "lint pre-conf no-build exit" || ok=1
    echo "$out" | python3 -c "import json,sys; d=json.load(sys.stdin); assert d.get('result')=='fail', d.get('result')" 2>/dev/null || { printf "\n    ${RED}lint response result must be fail${NC}\n"; ok=1; }
    echo "$out" | grep -q "forbidden" || { printf "\n    ${RED}lint response missing forbidden phrases${NC}\n"; ok=1; }
    rm -rf "$tmp"
    return $ok
}

