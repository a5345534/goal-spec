#!/usr/bin/env bash
# Test runner for goal-spec-workflow
#
# Covers:
#   - init artifact creation
#   - blocked gates for missing success signal / no-build / non-goal /
#     unresolved blocker questions
#   - pass status for a complete spec kernel
#   - proceed_with_assumptions failure without acknowledgement
#   - proceed_with_assumptions success with acknowledgement
#   - write-spec failure before the gate passes
#   - write-spec success after gate passes
#
# Deterministic validation: every check/gate/write-spec command emits stable
# JSON exit codes. This runner verifies both exit codes and key fields in the
# output payload.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
WORKFLOW="$SCRIPT_DIR/goal-spec-workflow"

PASS=0
FAIL=0
SKIP=0
TOTAL=0

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m' # No Color

# --- helpers ---

run_test() {
    local name="$1"
    shift
    TOTAL=$((TOTAL + 1))
    printf "  %-68s " "$name"
    if "$@"; then
        PASS=$((PASS + 1))
        printf "${GREEN}PASS${NC}\n"
    else
        FAIL=$((FAIL + 1))
        printf "${RED}FAIL${NC}\n"
    fi
}

assert_exit() {
    local expected="$1"
    local actual="$2"
    local label="$3"
    if [[ "$actual" -ne "$expected" ]]; then
        printf "\n    ${RED}%s: expected exit %d, got %d${NC}\n" "$label" "$expected" "$actual"
        return 1
    fi
    return 0
}

assert_json_field() {
    local json="$1"
    local field="$2"
    local expected="$3"
    local label="$4"
    local actual
    actual=$(echo "$json" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('$field',''))")
    if [[ "$actual" != "$expected" ]]; then
        printf "\n    ${RED}%s: expected '%s', got '%s'${NC}\n" "$label" "$expected" "$actual"
        return 1
    fi
    return 0
}

assert_json_path() {
    local json="$1"
    local path="$2"
    local expected="$3"
    local label="$4"
    local actual
    actual=$(echo "$json" | python3 -c "import json,sys; d=json.load(sys.stdin); parts='$path'.split('.'); v=d; [v:=v.get(p,None) for p in parts]; print(v if v is not None else '')")
    if [[ "$actual" != "$expected" ]]; then
        printf "\n    ${RED}%s: expected '%s', got '%s'${NC}\n" "$label" "$expected" "$actual"
        return 1
    fi
    return 0
}

# Create a minimal filled value-gate.json (status=pass) using python.
# All REQUIRED_PRE_SPEC_FIELDS populated.
filled_gate_pass() {
    local dir="$1"
    local change_name="${2:-test-change}"
    local capability="${3:-test-capability}"
    python3 -c "
import json, sys
from datetime import datetime, timezone
now = datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace('+00:00','Z')
gate = {
    'schemaVersion': '1.0',
    'status': 'pass',
    'changeName': '$change_name',
    'capability': '$capability',
    'goal': 'Validate the workflow helper produces correct gate outcomes across blocked, pass, proceed_with_assumptions, and write-spec paths.',
    'createdAt': now,
    'updatedAt': now,
    'valueFrame': {
        'beneficiary': 'developers using goal-spec',
        'problemOrOpportunity': 'The workflow helper needs deterministic test coverage.',
        'whyNow': 'Tests are required before the gate can be trusted in production.',
        'successSignal': 'All test scenarios pass with expected exit codes and JSON outputs.',
        'costRiskShape': 'Low — script-level tests with fixtures.',
        'noBuildCandidate': 'Manual spot-checking; rejected because it does not scale.',
        'smallerScopeCandidate': 'Test only exit codes; rejected because JSON output validation is also needed.',
        'scopeSummary': 'A bash test runner covering init, check, gate, and write-spec paths.',
        'verificationPath': 'Run scripts/test-workflow and observe no failures.',
    },
    'decision': {
        'rationale': 'The value gate must produce correct, consistent exit codes for agent-driven workflows.',
        'noBuildConsidered': 'Considered skipping tests; tests provide the primary deterministic validation.',
        'smallerScopeConsidered': 'Considered testing only check; extending to write-spec caught gate ordering bugs.',
    },
    'constraints': ['Only Python stdlib and bash; no pip/npm deps.'],
    'nonGoals': ['End-to-end OpenSpec validation (covered by other scripts).'],
    'assumptions': ['[ASSUMPTION] The workflow helper exit codes are stable.'],
    'risks': [],
    'openQuestions': [],
    'blockers': [],
    'acknowledgement': {
        'requiredFor': 'proceed_with_assumptions',
        'accepted': False,
        'acceptedAt': '',
        'acceptedBy': '',
        'rationale': '',
    },
}
print(json.dumps(gate))
"
}

